<?xml version="1.0" encoding="UTF-8"?>
<idea-plugin>
    <id>ai.yet.plugin</id>
    <name>Yet AI</name>
    <vendor>ai.yet</vendor>

    <description><![CDATA[
        <p>Yet AI local runtime host for JetBrains IDEs.</p>
        <p>This shell connects a JetBrains tool window to a local Yet AI runtime and GUI for local-first BYOK workflows.</p>
    ]]></description>

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <toolWindow id="Yet AI"
                    anchor="right"
                    canCloseContents="false"
                    factoryClass="ai.yet.plugin.ui.YetToolWindowFactory"/>
        <applicationConfigurable parentId="tools"
                                 instance="ai.yet.plugin.settings.YetSettingsConfigurable"
                                 id="ai.yet.plugin.settings"
                                 displayName="Yet AI"/>
        <applicationService serviceImplementation="ai.yet.plugin.settings.YetSettingsState"/>
        <applicationService serviceImplementation="ai.yet.plugin.settings.SessionTokenStore"/>
        <applicationService serviceImplementation="ai.yet.plugin.runtime.RuntimeConnectionManager"/>
        <projectService serviceImplementation="ai.yet.plugin.lsp.JetBrainsLspLifecycleService"/>
    </extensions>

    <actions>
        <group id="ai.yet.plugin.ToolsMenu"
               text="Yet AI"
               description="Yet AI local-first actions"
               popup="true">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
            <action id="ai.yet.plugin.OpenChat"
                    class="ai.yet.plugin.actions.OpenChatAction"
                    text="Yet AI: Open Chat"
                    description="Open the Yet AI local runtime chat shell"/>
            <action id="ai.yet.plugin.CopyDiagnostics"
                    class="ai.yet.plugin.actions.CopyYetDiagnosticsAction"
                    text="Yet AI: Copy Diagnostics"
                    description="Copy sanitized Yet AI runtime diagnostics to the clipboard"/>
            <action id="ai.yet.plugin.ShowRuntimeStatus"
                    class="ai.yet.plugin.actions.ShowRuntimeStatusAction"
                    text="Yet AI: Show Runtime Status"
                    description="Show sanitized Yet AI local runtime diagnostics"/>
            <action id="ai.yet.plugin.OpenLogsFolder"
                    class="ai.yet.plugin.actions.OpenYetLogsFolderAction"
                    text="Yet AI: Open Logs Folder"
                    description="Open the local Yet AI diagnostics log folder"/>
            <action id="ai.yet.plugin.RestartRuntime"
                    class="ai.yet.plugin.actions.RestartRuntimeAction"
                    text="Yet AI: Restart Runtime"
                    description="Restart the Yet AI local runtime process launched by this plugin"/>
        </group>
    </actions>
</idea-plugin>
