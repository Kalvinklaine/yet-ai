{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.yet-ai.example/contracts/engine/provider.schema.json",
  "title": "Engine Provider Summary",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "kind",
    "displayName",
    "enabled",
    "baseUrl",
    "auth",
    "models",
    "capabilities"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_-]{0,63}$"
    },
    "kind": {
      "type": "string",
      "enum": [
        "openai-compatible",
        "ollama",
        "custom"
      ]
    },
    "displayName": {
      "type": "string",
      "minLength": 1
    },
    "enabled": {
      "type": "boolean"
    },
    "baseUrl": {
      "type": "string",
      "minLength": 1
    },
    "auth": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "configured"
      ],
      "allOf": [
        {
          "if": {
            "properties": {
              "type": {
                "const": "api_key"
              },
              "configured": {
                "const": true
              }
            },
            "required": [
              "type",
              "configured"
            ]
          },
          "then": {
            "properties": {
              "redacted": true
            },
            "required": [
              "redacted"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "none"
              }
            },
            "required": [
              "type"
            ]
          },
          "then": {
            "not": {
              "required": [
                "redacted"
              ]
            }
          }
        }
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "none",
            "api_key"
          ]
        },
        "configured": {
          "type": "boolean"
        },
        "redacted": {
          "description": "Required only when type is api_key and configured is true. Raw secrets must never appear here.",
          "type": "string",
          "minLength": 1
        }
      }
    },
    "models": {
      "description": "Sanitized provider model summaries with normalized capability and readiness metadata.",
      "type": "array",
      "items": {
        "$ref": "./models.schema.json#/$defs/model"
      }
    },
    "capabilities": {
      "$ref": "#/$defs/providerCapabilities"
    },
    "providerFamily": {
      "$ref": "#/$defs/providerFamily"
    }
  },
  "$defs": {
    "providerCapabilities": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "chat",
        "completion",
        "embeddings"
      ],
      "properties": {
        "chat": {
          "type": "boolean"
        },
        "completion": {
          "type": "boolean"
        },
        "embeddings": {
          "type": "boolean"
        }
      }
    },
    "capabilityProvenanceValue": {
      "type": "string",
      "enum": [
        "configured",
        "runtime_tested",
        "provider_declared",
        "local_default"
      ]
    },
    "providerTestStatus": {
      "type": "string",
      "enum": [
        "reachable",
        "unsupported_kind",
        "missing_secret",
        "missing_model",
        "bad_url",
        "unauthorized",
        "timeout",
        "unreachable",
        "upstream_error"
      ]
    },
    "utcTimestamp": {
      "type": "string",
      "format": "date-time",
      "pattern": "Z$"
    },
    "providerFamily": {
      "type": "string",
      "enum": [
        "openai_compatible",
        "ollama",
        "custom",
        "demo_local"
      ]
    },
    "sanitizedAvailabilityReason": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160,
      "not": {
        "pattern": "[Aa][Pp][Ii][_ -]?[Kk][Ee][Yy]|[Ss][Ee][Cc][Rr][Ee][Tt]|[Tt][Oo][Kk][Ee][Nn]|[Pp][Aa][Ss][Ss][Ww][Oo][Rr][Dd]|[Cc][Rr][Ee][Dd][Ee][Nn][Tt][Ii][Aa][Ll]|[Aa][Uu][Tt][Hh][Oo][Rr][Ii][Zz][Aa][Tt][Ii][Oo][Nn]|[Cc][Oo][Oo][Kk][Ii][Ee]|[Bb][Ee][Aa][Rr][Ee][Rr]|[Rr][Aa][Ww][_ -]?[Pp][Rr][Oo][Vv][Ii][Dd][Ee][Rr]|[Pp][Rr][Oo][Vv][Ii][Dd][Ee][Rr][_ -]?[Rr][Ee][Ss][Pp][Oo][Nn][Ss][Ee]|[Rr][Ee][Ss][Pp][Oo][Nn][Ss][Ee][_ -]?[Bb][Oo][Dd][Yy]|/[Uu]sers/|/[Hh]ome/|/[Pp]rivate/|/[Tt]mp/|/[Ee]tc/|~[/\\]|[A-Za-z]:\\\\"
      }
    },
    "capabilityProvenance": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "chat": {
          "$ref": "#/$defs/capabilityProvenanceValue"
        },
        "streaming": {
          "$ref": "#/$defs/capabilityProvenanceValue"
        },
        "tools": {
          "$ref": "#/$defs/capabilityProvenanceValue"
        },
        "reasoning": {
          "$ref": "#/$defs/capabilityProvenanceValue"
        }
      }
    },
    "localAvailability": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "unknown",
            "not_applicable",
            "reachable",
            "unreachable",
            "missing_model"
          ]
        },
        "checkedAt": {
          "$ref": "#/$defs/utcTimestamp"
        },
        "reason": {
          "$ref": "#/$defs/sanitizedAvailabilityReason"
        }
      }
    }
  }
}
