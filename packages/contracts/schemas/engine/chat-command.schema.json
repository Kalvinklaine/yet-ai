{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.yet-ai.example/contracts/engine/chat-command.schema.json",
  "title": "Engine Chat Command Request",
  "description": "Current non-privileged chat commands only. Tool decisions, IDE tool results, message mutation, regeneration, and parameter changes remain disabled until strict schemas, policy, and confirmation are implemented.",
  "type": "object",
  "additionalProperties": false,
  "required": ["requestId", "type"],
  "properties": {
    "requestId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "type": {
      "type": "string",
      "enum": ["user_message", "abort"]
    },
    "payload": {
      "type": "object"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "type": {
            "const": "user_message"
          }
        },
        "required": ["type"]
      },
      "then": {
        "required": ["payload"],
        "properties": {
          "payload": {
            "type": "object",
            "additionalProperties": false,
            "required": ["content"],
            "properties": {
              "content": {
                "type": "string",
                "minLength": 1,
                "maxLength": 20000
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "abort"
          }
        },
        "required": ["type"]
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "additionalProperties": false,
            "maxProperties": 0
          }
        }
      }
    }
  ]
}
