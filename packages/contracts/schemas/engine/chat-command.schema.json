{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.yet-ai.example/contracts/engine/chat-command.schema.json",
  "title": "Engine Chat Command Request",
  "description": "Current non-privileged chat commands only. Tool decisions, IDE tool results, message mutation, regeneration, parameter changes, file edits, shell-like actions, and workspace mutation remain disabled until strict schemas, policy, and confirmation are implemented.",
  "type": "object",
  "additionalProperties": false,
  "required": ["requestId", "type"],
  "properties": {
    "requestId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "type": {
      "type": "string",
      "enum": ["user_message", "abort"]
    },
    "payload": {
      "type": "object"
    }
  },
  "$defs": {
    "safeRelativePath": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512,
      "pattern": "^(?!/)(?!~)(?!.*//)(?!.*/$)(?!.*(?:^|/)\\.\\.?(?:/|$))(?!.*(?:^|/)(?:auth|authorization|bearer|cookie|credential|credentials|password|secret|token|access[_-]?token|accesstoken|api[_-]?key|apikey)(?:[._-]|/|$))(?!.*(?:^|/)[^/]*(?:[._-])(?:auth|credential|credentials|password|secret|token|access[_-]?token|accesstoken|api[_-]?key|apikey)(?:[._-]|/|$))(?!.*(?:^|/)sk-(?:proj-)?[A-Za-z0-9_-]{8,})[A-Za-z0-9/._@+=-]+$"
    },
    "safeDisplayPath": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "pattern": "^(?!/)(?!~)(?!.*//)(?!.*/$)(?!.*(?:^|/)\\.\\.?(?:/|$))(?!.*(?:^|/)(?:auth|authorization|bearer|cookie|credential|credentials|password|secret|token|access[_-]?token|accesstoken|api[_-]?key|apikey)(?:[._-]|/|$))(?!.*(?:^|/)[^/]*(?:[._-])(?:auth|credential|credentials|password|secret|token|access[_-]?token|accesstoken|api[_-]?key|apikey)(?:[._-]|/|$))(?!.*(?:^|/)sk-(?:proj-)?[A-Za-z0-9_-]{8,})[A-Za-z0-9/._@+=-]+$"
    },
    "activeEditorContext": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "source"],
      "properties": {
        "kind": {
          "type": "string",
          "const": "active_editor"
        },
        "source": {
          "type": "string",
          "enum": ["vscode", "jetbrains", "browser"]
        },
        "file": {
          "type": "object",
          "additionalProperties": false,
          "minProperties": 1,
          "properties": {
            "displayPath": {
              "$ref": "#/$defs/safeDisplayPath"
            },
            "workspaceRelativePath": {
              "$ref": "#/$defs/safeRelativePath"
            },
            "languageId": {
              "type": "string",
              "minLength": 1,
              "maxLength": 64,
              "pattern": "^[A-Za-z0-9_.+-]+$"
            }
          }
        },
        "selection": {
          "type": "object",
          "additionalProperties": false,
          "minProperties": 1,
          "properties": {
            "startLine": {
              "type": "integer",
              "minimum": 0,
              "maximum": 1000000
            },
            "startCharacter": {
              "type": "integer",
              "minimum": 0,
              "maximum": 1000000
            },
            "endLine": {
              "type": "integer",
              "minimum": 0,
              "maximum": 1000000
            },
            "endCharacter": {
              "type": "integer",
              "minimum": 0,
              "maximum": 1000000
            },
            "text": {
              "type": "string",
              "maxLength": 8000
            }
          }
        }
      }
    },
    "explicitContextBundle": {
      "type": "object",
      "additionalProperties": false,
      "maxTotalSelectionText": 16000,
      "required": ["kind", "items"],
      "properties": {
        "kind": {
          "type": "string",
          "const": "explicit_context_bundle"
        },
        "items": {
          "type": "array",
          "minItems": 1,
          "maxItems": 4,
          "items": {
            "oneOf": [
              {
                "$ref": "#/$defs/activeEditorContext"
              },
              {
                "$ref": "#/$defs/verificationOutputContext"
              }
            ]
          }
        }
      }
    },
    "verificationOutputTail": {
      "type": "string",
      "maxLength": 4000,
      "pattern": "^(?!.*(?:[\\u0000-\\u0008\\u000b\\u000c\\u000e-\\u001f\\u007f-\\u009f]|[Aa][Uu][Tt][Hh][Oo][Rr][Ii][Zz][Aa][Tt][Ii][Oo][Nn]|[Bb][Ee][Aa][Rr][Ee][Rr]|[Cc][Oo][Oo][Kk][Ii][Ee]|[Aa][Pp][Ii][_-]?[Kk][Ee][Yy]|[Tt][Oo][Kk][Ee][Nn]|[Ss][Ee][Cc][Rr][Ee][Tt]|[Pp][Aa][Ss][Ss][Ww][Oo][Rr][Dd]|[Pp][Rr][Ii][Vv][Aa][Tt][Ee][_-]?[Pp][Aa][Tt][Hh]|[Pp][Rr][Oo][Vv][Ii][Dd][Ee][Rr][_-]?[Rr][Ee][Ss][Pp][Oo][Nn][Ss][Ee]|[Rr][Aa][Ww][_-]?[Pp][Rr][Oo][Mm][Pp][Tt]|[Ff][Ii][Ll][Ee][_-]?[Cc][Oo][Nn][Tt][Ee][Nn][Tt]|/[Uu][Ss][Ee][Rr][Ss](?=/|$|[^A-Za-z0-9_])|/[Hh][Oo][Mm][Ee](?=/|$|[^A-Za-z0-9_])|/[Tt][Mm][Pp](?=/|$|[^A-Za-z0-9_])|/[Vv][Aa][Rr](?=/|$|[^A-Za-z0-9_])|/[Ee][Tt][Cc](?=/|$|[^A-Za-z0-9_])|/[Oo][Pp][Tt](?=/|$|[^A-Za-z0-9_])|/[Mm][Nn][Tt](?=/|$|[^A-Za-z0-9_])|/[Vv][Oo][Ll][Uu][Mm][Ee][Ss](?=/|$|[^A-Za-z0-9_])|/[Pp][Rr][Ii][Vv][Aa][Tt][Ee](?=/|$|[^A-Za-z0-9_])|[A-Za-z]:(?:/|\\\\)|~(?:/|\\\\)|(?:^|[^A-Za-z0-9_-])[Ss][Kk]-(?:[Pp][Rr][Oo][Jj]-)?[A-Za-z0-9_-]{8,}))[\\s\\S]*$"
    },
    "verificationOutputContext": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "commandId",
        "exitCode",
        "status",
        "outputTail",
        "truncated"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "const": "verification_output"
        },
        "commandId": {
          "type": "string",
          "enum": [
            "repository-check",
            "gui-app-tests",
            "engine-chat-tests"
          ]
        },
        "exitCode": {
          "type": "integer",
          "minimum": 0,
          "maximum": 255
        },
        "status": {
          "type": "string",
          "enum": [
            "succeeded",
            "failed"
          ]
        },
        "outputTail": {
          "$ref": "#/$defs/verificationOutputTail"
        },
        "truncated": {
          "type": "boolean"
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "type": {
            "const": "user_message"
          }
        },
        "required": ["type"]
      },
      "then": {
        "required": ["payload"],
        "properties": {
          "payload": {
            "type": "object",
            "additionalProperties": false,
            "required": ["content"],
            "properties": {
              "content": {
                "type": "string",
                "minLength": 1,
                "maxLength": 20000
              },
              "context": {
                "oneOf": [
                  {
                    "$ref": "#/$defs/activeEditorContext"
                  },
                  {
                    "$ref": "#/$defs/explicitContextBundle"
                  }
                ]
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "abort"
          }
        },
        "required": ["type"]
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "additionalProperties": false,
            "maxProperties": 0
          }
        }
      }
    }
  ]
}
