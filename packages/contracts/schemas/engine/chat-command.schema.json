{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.yet-ai.example/contracts/engine/chat-command.schema.json",
  "title": "Engine Chat Command Request",
  "description": "Current non-privileged chat commands only. Tool decisions, IDE tool results, message mutation, regeneration, parameter changes, file edits, shell-like actions, and workspace mutation remain disabled until strict schemas, policy, and confirmation are implemented.",
  "type": "object",
  "additionalProperties": false,
  "required": ["requestId", "type"],
  "properties": {
    "requestId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "type": {
      "type": "string",
      "enum": ["user_message", "abort"]
    },
    "payload": {
      "type": "object"
    }
  },
  "$defs": {
    "safeRelativePath": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512,
      "pattern": "^(?!/)(?!~)(?!.*\\\\)(?!.*:)(?!.*(?:^|/)\\.\\.?(?:/|$))[^\\u0000-\\u001f]+$"
    },
    "safeDisplayPath": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "pattern": "^(?!/)(?!~)(?!.*\\\\)(?!.*:)(?!.*(?:^|/)\\.\\.?(?:/|$))[^\\u0000-\\u001f]+$"
    },
    "activeEditorContext": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "source"],
      "properties": {
        "kind": {
          "type": "string",
          "const": "active_editor"
        },
        "source": {
          "type": "string",
          "enum": ["vscode", "jetbrains", "browser"]
        },
        "file": {
          "type": "object",
          "additionalProperties": false,
          "minProperties": 1,
          "properties": {
            "displayPath": {
              "$ref": "#/$defs/safeDisplayPath"
            },
            "workspaceRelativePath": {
              "$ref": "#/$defs/safeRelativePath"
            },
            "languageId": {
              "type": "string",
              "minLength": 1,
              "maxLength": 64,
              "pattern": "^[A-Za-z0-9_.+-]+$"
            }
          }
        },
        "selection": {
          "type": "object",
          "additionalProperties": false,
          "minProperties": 1,
          "properties": {
            "startLine": {
              "type": "integer",
              "minimum": 0,
              "maximum": 1000000
            },
            "startCharacter": {
              "type": "integer",
              "minimum": 0,
              "maximum": 1000000
            },
            "endLine": {
              "type": "integer",
              "minimum": 0,
              "maximum": 1000000
            },
            "endCharacter": {
              "type": "integer",
              "minimum": 0,
              "maximum": 1000000
            },
            "text": {
              "type": "string",
              "maxLength": 8000
            }
          }
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "type": {
            "const": "user_message"
          }
        },
        "required": ["type"]
      },
      "then": {
        "required": ["payload"],
        "properties": {
          "payload": {
            "type": "object",
            "additionalProperties": false,
            "required": ["content"],
            "properties": {
              "content": {
                "type": "string",
                "minLength": 1,
                "maxLength": 20000
              },
              "context": {
                "$ref": "#/$defs/activeEditorContext"
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "abort"
          }
        },
        "required": ["type"]
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "additionalProperties": false,
            "maxProperties": 0
          }
        }
      }
    }
  ]
}
