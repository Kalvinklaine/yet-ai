{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.yet-ai.example/contracts/engine/project-error.schema.json",
  "title": "Engine Sanitized Project Error",
  "description": "Stable project-control error with a short generic message and no echoed identifier, handle, root, path, URI, filesystem detail, token, or credential.",
  "type": "object",
  "additionalProperties": false,
  "required": ["category", "message", "cloudRequired", "providerAccess"],
  "properties": {
    "category": { "enum": ["invalid_request", "not_found", "archived", "root_missing", "discovery_expired", "outside_allowed_root", "unsafe_filesystem", "storage_unavailable"] },
    "message": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160,
      "pattern": "^(?!\\s)(?![\\s\\S]*\\s$)(?![\\s\\S]*(?:[Aa][Pp][Ii][-_ ]?[Kk][Ee][Yy]|[Aa][Uu][Tt][Hh][Oo][Rr][Ii][Zz][Aa][Tt][Ii][Oo][Nn]|[Bb][Ee][Aa][Rr][Ee][Rr]|[Tt][Oo][Kk][Ee][Nn]|[Ss][Ee][Cc][Rr][Ee][Tt]|[Pp][Aa][Ss][Ss][Ww][Oo][Rr][Dd]|[Ss][Ee][Ss][Ss][Ii][Oo][Nn][-_ ]?[Ii][Dd]|[Dd][Ii][Rr][Ee][Cc][Tt][Oo][Rr][Yy][-_ ]?[Hh][Aa][Nn][Dd][Ll][Ee]|(?:^|[^A-Za-z0-9_-])[Ss][Kk]-(?:[Pp][Rr][Oo][Jj]-)?[A-Za-z0-9_-]{8,}|/[Uu][Ss][Ee][Rr][Ss](?:/|$)|/[Hh][Oo][Mm][Ee](?:/|$)|/[Tt][Mm][Pp](?:/|$)|[A-Za-z]:(?:/|\\\\)|~(?:/|\\\\)|https?://|file:))[^\\x00-\\x1F\\x7F]+$"
    },
    "cloudRequired": { "const": false },
    "providerAccess": { "const": "direct" }
  }
}
