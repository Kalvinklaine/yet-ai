{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.yet-ai.example/contracts/engine/controlled-agent-edit-executor.schema.json",
  "title": "Controlled Agent Edit Executor Metadata",
  "description": "Strict replacement-edit metadata contract for existing workspace files. It grants no create, delete, rename, move, chmod, symlink, binary, raw body, raw diff, raw patch, command, cwd, env, shell, git, provider, tool, bridge, runtime endpoint, or autonomous edit authority.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "type",
    "schemaVersion",
    "state",
    "runId",
    "workspaceReadinessId",
    "requestId",
    "requestIdMintedBy",
    "userConfirmed",
    "limits",
    "edits"
  ],
  "properties": {
    "type": {
      "type": "string",
      "const": "controlled_agent_edit_executor"
    },
    "schemaVersion": {
      "type": "string",
      "const": "2026-07-02"
    },
    "state": {
      "type": "string",
      "enum": ["disabled", "planned", "applied", "blocked", "failed"]
    },
    "runId": {
      "$ref": "#/$defs/safeId"
    },
    "workspaceReadinessId": {
      "$ref": "#/$defs/safeId"
    },
    "requestId": {
      "$ref": "#/$defs/safeId"
    },
    "requestIdMintedBy": {
      "type": "string",
      "enum": ["gui", "host", "runtime"]
    },
    "userConfirmed": {
      "type": "boolean"
    },
    "limits": {
      "type": "object",
      "additionalProperties": false,
      "required": ["maxFiles", "maxEdits", "maxPatchBytes"],
      "properties": {
        "maxFiles": {
          "type": "integer",
          "minimum": 1,
          "maximum": 50
        },
        "maxEdits": {
          "type": "integer",
          "minimum": 1,
          "maximum": 500
        },
        "maxPatchBytes": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1048576
        }
      }
    },
    "edits": {
      "type": "array",
      "maxItems": 500,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "operation",
          "workspaceRelativePath",
          "fileLabel",
          "expectedContentHash",
          "startLine",
          "endLine",
          "replacementByteCount",
          "sanitizedSummary"
        ],
        "properties": {
          "operation": {
            "type": "string",
            "const": "replace"
          },
          "workspaceRelativePath": {
            "$ref": "#/$defs/workspaceRelativePath"
          },
          "fileLabel": {
            "$ref": "#/$defs/fileLabel"
          },
          "expectedContentHash": {
            "$ref": "#/$defs/sha256Hash"
          },
          "startLine": {
            "type": "integer",
            "minimum": 1,
            "maximum": 1000000
          },
          "endLine": {
            "type": "integer",
            "minimum": 1,
            "maximum": 1000000
          },
          "replacementByteCount": {
            "type": "integer",
            "minimum": 0,
            "maximum": 1048576
          },
          "sanitizedSummary": {
            "$ref": "#/$defs/sanitizedSummary"
          }
        },
        "allOf": [
          {
            "properties": {
              "endLine": {
                "type": "integer",
                "minimum": { "$data": "1/startLine" }
              }
            }
          }
        ]

      }
    }
  },
  "$defs": {
    "safeText": {
      "type": "string",
      "pattern": "^(?![\\s\\S]*(?:[Aa][Pp][Ii][-_ ]?[Kk][Ee][Yy]|[Aa][Uu][Tt][Hh][Oo][Rr][Ii][Zz][Aa][Tt][Ii][Oo][Nn]|[Bb][Ee][Aa][Rr][Ee][Rr]|[Cc][Oo][Oo][Kk][Ii][Ee]|[Tt][Oo][Kk][Ee][Nn]|[Ss][Ee][Cc][Rr][Ee][Tt]|[Pp][Aa][Ss][Ss][Ww][Oo][Rr][Dd]|[Rr][Aa][Ww][-_ ]?(?:[Ff][Ii][Ll][Ee]|[Bb][Oo][Dd][Yy]|[Pp][Aa][Tt][Cc][Hh]|[Dd][Ii][Ff][Ff]|[Cc][Oo][Mm][Mm][Aa][Nn][Dd])|[Ff][Ii][Ll][Ee][-_ ]?(?:[Bb][Oo][Dd][Yy]|[Cc][Oo][Nn][Tt][Ee][Nn][Tt])|[Pp][Rr][Oo][Vv][Ii][Dd][Ee][Rr]|[Ss][Hh][Ee][Ll][Ll]|[Cc][Oo][Mm][Mm][Aa][Nn][Dd]|[Cc][Ww][Dd]|[Ee][Nn][Vv]|[Gg][Ii][Tt]|[Tt][Oo][Oo][Ll]|[Cc][Hh][Mm][Oo][Dd]|[Ss][Yy][Mm][Ll][Ii][Nn][Kk]|[Bb][Ii][Nn][Aa][Rr][Yy]|[Cc][Rr][Ee][Aa][Tt][Ee]|[Dd][Ee][Ll][Ee][Tt][Ee]|[Rr][Ee][Nn][Aa][Mm][Ee]|[Mm][Oo][Vv][Ee]|[Aa][Uu][Tt][Oo][-_ ]?(?:[Aa][Pp][Pp][Ll][Yy]|[Rr][Uu][Nn]|[Rr][Ee][Pp][Aa][Ii][Rr])|(?:^|[^A-Za-z0-9_-])[Ss][Kk]-(?:[Pp][Rr][Oo][Jj]-)?[A-Za-z0-9_-]{8,}|/[Uu][Ss][Ee][Rr][Ss](?=/|$|[^A-Za-z0-9_])|/[Hh][Oo][Mm][Ee](?=/|$|[^A-Za-z0-9_])|/[Tt][Mm][Pp](?=/|$|[^A-Za-z0-9_])|/[Vv][Aa][Rr](?=/|$|[^A-Za-z0-9_])|/[Ee][Tt][Cc](?=/|$|[^A-Za-z0-9_])|/[Pp][Rr][Ii][Vv][Aa][Tt][Ee](?=/|$|[^A-Za-z0-9_])|[A-Za-z]:(?:/|\\\\)|~(?:/|\\\\)|[Bb][Ee][Gg][Ii][Nn] [A-Za-z ]*[Pp][Rr][Ii][Vv][Aa][Tt][Ee] [Kk][Ee][Yy]))[\\s\\S]*$"
    },
    "safeId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120,
      "pattern": "^(?!assistant(?:[._:-]|$))(?!.*(?:[Aa][Ss][Ss][Ii][Ss][Tt][Aa][Nn][Tt]|[Ss][Kk]-(?:[Pp][Rr][Oo][Jj]-)?))[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "workspaceRelativePath": {
      "type": "string",
      "minLength": 1,
      "maxLength": 180,
      "pattern": "^(?!/)(?![A-Za-z]:)(?!~)(?!.*(?:^|/)\\.)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*//)(?!.*[\\\\:*?\"<>|{}\\[\\]$^+])(?!(?:^|.*/)(?:node_modules|vendor|dist|build|out|target|coverage|__pycache__|generated|tmp|temp|secrets?|credentials?|private)(?:/|$))[A-Za-z0-9][A-Za-z0-9._-]*(?:/[A-Za-z0-9][A-Za-z0-9._-]*)*$"
    },
    "fileLabel": {
      "allOf": [
        { "$ref": "#/$defs/safeText" },
        { "type": "string", "minLength": 1, "maxLength": 160 }
      ]
    },
    "sanitizedSummary": {
      "allOf": [
        { "$ref": "#/$defs/safeText" },
        { "type": "string", "minLength": 1, "maxLength": 240 }
      ]
    },
    "sha256Hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "state": {
            "enum": ["planned", "applied", "blocked", "failed"]
          }
        },
        "required": ["state"]
      },
      "then": {
        "properties": {
          "userConfirmed": {
            "const": true
          }
        },
        "required": ["userConfirmed"]
      }
    }
  ]
}
