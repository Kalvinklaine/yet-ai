{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.yet-ai.example/contracts/engine/caps.schema.json",
  "title": "Engine Capabilities Response",
  "type": "object",
  "additionalProperties": false,
  "required": ["productId", "protocolVersion", "runtime", "capabilities", "features", "providers", "ide"],
  "properties": {
    "productId": {
      "type": "string",
      "minLength": 1
    },
    "protocolVersion": {
      "type": "string",
      "minLength": 1
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "cloudRequired", "providerAccess"],
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["local"]
        },
        "cloudRequired": {
          "type": "boolean",
          "const": false
        },
        "providerAccess": {
          "type": "string",
          "enum": ["direct"]
        }
      }
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "features": {
      "type": "object",
      "additionalProperties": {
        "type": "boolean"
      }
    },
    "providers": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "displayName", "enabled", "models"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "displayName": {
            "type": "string",
            "minLength": 1
          },
          "enabled": {
            "type": "boolean"
          },
          "models": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/model"
            }
          }
        }
      }
    },
    "ide": {
      "type": "object",
      "additionalProperties": false,
      "required": ["bridge", "lsp"],
      "properties": {
        "bridge": {
          "type": "boolean"
        },
        "lsp": {
          "type": "boolean"
        },
        "host": {
          "type": "string"
        }
      }
    }
  },
  "$defs": {
    "model": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "displayName", "capabilities", "readiness"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "displayName": {
          "type": "string",
          "minLength": 1
        },
        "providerId": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9_-]{0,63}$"
        },
        "capabilities": {
          "$ref": "#/$defs/modelCapabilities"
        },
        "readiness": {
          "$ref": "#/$defs/modelReadiness"
        }
      }
    },
    "modelCapabilities": {
      "type": "object",
      "additionalProperties": false,
      "required": ["chat", "streaming", "tools", "reasoning"],
      "properties": {
        "chat": {
          "type": "boolean"
        },
        "streaming": {
          "type": "boolean"
        },
        "tools": {
          "type": "boolean"
        },
        "reasoning": {
          "type": "boolean"
        }
      }
    },
    "modelReadiness": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["ready", "disabled", "missing_credentials", "missing_model", "unsupported"]
        },
        "reason": {
          "type": "string",
          "minLength": 1,
          "maxLength": 160,
          "not": {
            "pattern": "[Aa][Pp][Ii][_ -]?[Kk][Ee][Yy]|[Ss][Ee][Cc][Rr][Ee][Tt]|[Tt][Oo][Kk][Ee][Nn]|[Pp][Aa][Ss][Ss][Ww][Oo][Rr][Dd]|[Cc][Rr][Ee][Dd][Ee][Nn][Tt][Ii][Aa][Ll]|[Aa][Uu][Tt][Hh][Oo][Rr][Ii][Zz][Aa][Tt][Ii][Oo][Nn]|[Cc][Oo][Oo][Kk][Ii][Ee]"
          }
        }
      }
    }

  }
}
