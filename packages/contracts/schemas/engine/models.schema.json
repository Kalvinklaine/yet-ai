{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.yet-ai.example/contracts/engine/models.schema.json",
  "title": "Engine Models Response",
  "type": "object",
  "additionalProperties": false,
  "required": ["models"],
  "properties": {
    "models": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/model"
      }
    }
  },
  "$defs": {
    "model": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "displayName"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "displayName": {
          "type": "string",
          "minLength": 1
        },
        "providerId": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9_-]{0,63}$"
        }
      }
    }
  }
}
