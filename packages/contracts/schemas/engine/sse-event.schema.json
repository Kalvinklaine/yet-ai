{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.yet-ai.example/contracts/engine/sse-event.schema.json",
  "title": "Engine SSE Event",
  "description": "Events are ordered by seq within a chat stream. A snapshot event resets client state and sequence tracking.",
  "type": "object",
  "additionalProperties": false,
  "required": ["seq", "type", "chatId"],
  "properties": {
    "seq": {
      "type": "integer",
      "minimum": 0
    },
    "type": {
      "type": "string",
      "enum": [
        "snapshot",
        "stream_started",
        "stream_delta",
        "stream_finished",
        "message_added",
        "message_updated",
        "message_removed",
        "thread_updated",
        "runtime_updated",
        "queue_updated",
        "pause_required",
        "ide_tool_required",
        "error"
      ]
    },
    "chatId": {
      "type": "string",
      "minLength": 1
    },
    "payload": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "type": {
            "const": "error"
          }
        },
        "required": ["type"]
      },
      "then": {
        "required": ["payload"],
        "properties": {
          "payload": {
            "type": "object",
            "additionalProperties": false,
            "required": ["code", "message"],
            "properties": {
              "code": {
                "type": "string",
                "enum": [
                  "provider_not_configured",
                  "model_not_configured",
                  "provider_unauthorized",
                  "provider_rate_limited",
                  "provider_context_too_large",
                  "provider_invalid_request",
                  "provider_timeout",
                  "provider_upstream_error",
                  "provider_malformed_stream",
                  "provider_config_error",
                  "provider_request_failed"
                ]
              },
              "message": {
                "type": "string",
                "minLength": 1,
                "maxLength": 240,
                "not": {
                  "pattern": "([sS][kK]-|[bB][eE][aA][rR][eE][rR]|[aA][uU][tT][hH][oO][rR][iI][zZ][aA][tT][iI][oO][nN]|[aA][cC][cC][eE][sS][sS]_[tT][oO][kK][eE][nN]|[rR][eE][fF][rR][eE][sS][hH]_[tT][oO][kK][eE][nN]|[aA][pP][iI][_-]?[kK][eE][yY]|[cC][oO][oO][kK][iI][eE]|/[uU][sS][eE][rR][sS]/|/[hH][oO][mM][eE]/)"
                }
              }
            }
          }
        }
      }
    }
  ]
}
