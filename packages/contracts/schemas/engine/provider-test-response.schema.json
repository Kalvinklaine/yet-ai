{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.yet-ai.example/contracts/engine/provider-test-response.schema.json",
  "title": "Engine Provider Test Response",
  "type": "object",
  "additionalProperties": false,
  "required": ["ok", "providerId", "status", "message", "cloudRequired"],
  "allOf": [
    {
      "if": {
        "properties": {
          "ok": { "const": true }
        },
        "required": ["ok"]
      },
      "then": {
        "properties": {
          "status": { "const": "reachable" }
        }
      }
    },
    {
      "if": {
        "properties": {
          "ok": { "const": false }
        },
        "required": ["ok"]
      },
      "then": {
        "properties": {
          "status": {
            "enum": [
              "unsupported_kind",
              "missing_secret",
              "missing_model",
              "bad_url",
              "unauthorized",
              "timeout",
              "unreachable",
              "upstream_error"
            ]
          }
        }
      }
    }
  ],
  "properties": {
    "ok": {
      "type": "boolean"
    },
    "providerId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_-]{0,63}$"
    },
    "status": {
      "type": "string",
      "enum": [
        "reachable",
        "unsupported_kind",
        "missing_secret",
        "missing_model",
        "bad_url",
        "unauthorized",
        "timeout",
        "unreachable",
        "upstream_error"
      ]
    },
    "message": {
      "type": "string"
    },
    "modelId": {
      "type": "string",
      "minLength": 1
    },
    "cloudRequired": {
      "type": "boolean",
      "const": false
    }
  }
}
