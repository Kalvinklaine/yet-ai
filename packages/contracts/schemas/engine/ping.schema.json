{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.yet-ai.example/contracts/engine/ping.schema.json",
  "title": "Engine Ping Response",
  "type": "object",
  "additionalProperties": false,
  "required": ["productId", "displayName", "version", "ready", "serverTime"],
  "properties": {
    "productId": {
      "type": "string",
      "minLength": 1
    },
    "displayName": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "ready": {
      "type": "boolean"
    },
    "serverTime": {
      "type": "string",
      "format": "date-time"
    }
  }
}
