{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.yet-ai.example/contracts/engine/agent-progress-event.schema.json",
  "title": "Agent Progress Event",
  "description": "Local planner/agent progress event with bounded sanitized operational status only. It excludes raw prompts, chain-of-thought, provider responses, secrets, private paths, credential paths, and workspace file contents.",
  "type": "object",
  "additionalProperties": false,
  "required": ["protocolVersion", "eventId", "runId", "cardId", "timestamp", "phase", "status", "message"],
  "properties": {
    "protocolVersion": {
      "type": "string",
      "const": "2026-05-29"
    },
    "eventId": {
      "$ref": "#/$defs/id"
    },
    "runId": {
      "$ref": "#/$defs/id"
    },
    "cardId": {
      "$ref": "#/$defs/cardId"
    },
    "timestamp": {
      "$ref": "#/$defs/timestamp"
    },
    "phase": {
      "$ref": "#/$defs/phase"
    },
    "status": {
      "$ref": "#/$defs/status"
    },
    "message": {
      "$ref": "#/$defs/safeMessage"
    },
    "tool": {
      "$ref": "#/$defs/toolSummary"
    },
    "heartbeat": {
      "$ref": "#/$defs/heartbeat"
    },
    "outputTail": {
      "$ref": "#/$defs/outputTail"
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.-]{0,127}$"
    },
    "cardId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_-]{0,63}$"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "minLength": 20,
      "maxLength": 32
    },
    "phase": {
      "type": "string",
      "enum": ["queued", "started", "reading_context", "editing", "running_command", "waiting_for_tool", "verifying", "finishing", "done", "failed", "stuck"]
    },
    "status": {
      "type": "string",
      "enum": ["pending", "running", "healthy_running", "long_running", "stalled", "stuck", "done", "failed"]
    },
    "safeText": {
      "type": "string",
      "pattern": "^(?![\\s\\S]*(?:[aA][pP][iI][-_ ]?[kK][eE][yY]|[aA][uU][tT][hH][oO][rR][iI][zZ][aA][tT][iI][oO][nN]|[bB][eE][aA][rR][eE][rR]|[tT][oO][kK][eE][nN]|[sS][eE][cC][rR][eE][tT]|[pP][aA][sS][sS][wW][oO][rR][dD]|[cC][oO][oO][kK][iI][eE]|[pP][kK][cC][eE]|[rR][eE][fF][rR][eE][sS][hH]|[aA][cC][cC][eE][sS][sS][-_ ]?[tT][oO][kK][eE][nN]|[aA][uU][tT][hH][-_ ]?[cC][oO][dD][eE]|[cC][hH][aA][iI][nN][-_ ]?[oO][fF][-_ ]?[tT][hH][oO][uU][gG][hH][tT]|[rR][aA][wW][-_ ]?(?:[pP][rR][oO][mM][pP][tT]|[dD][uU][mM][pP]|[oO][uU][tT][pP][uU][tT]|[fF][iI][lL][eE]|[wW][oO][rR][kK][sS][pP][aA][cC][eE])|[pP][rR][oO][vV][iI][dD][eE][rR][-_ ]?(?:[rR][eE][sS][pP][oO][nN][sS][eE]|[bB][oO][dD][yY])|[cC][rR][eE][dD][eE][nN][tT][iI][aA][lL]|[fF][iI][lL][eE][-_ ]?[cC][oO][nN][tT][eE][nN][tT]|[wW][oO][rR][kK][sS][pP][aA][cC][eE][-_ ]?(?:[fF][iI][lL][eE]|[cC][oO][nN][tT][eE][nN][tT])|/Users/|/home/|/private/|[A-Za-z]:\\\\|~/|\\.[cC][oO][dD][eE][xX]/[aA][uU][tT][hH]\\.json|(?:[aA][uU][tT][hH]|[cC][rR][eE][dD][eE][nN][tT][iI][aA][lL][sS]?)\\.json|BEGIN [A-Z ]*PRIVATE KEY))[\\s\\S]*$"
    },
    "safeMessage": {
      "allOf": [
        { "$ref": "#/$defs/safeText" },
        {
          "type": "string",
          "minLength": 1,
          "maxLength": 280
        }
      ]
    },
    "outputTail": {
      "allOf": [
        { "$ref": "#/$defs/safeText" },
        {
          "type": "string",
          "maxLength": 2000
        }
      ]
    },
    "toolKind": {
      "type": "string",
      "enum": ["read", "edit", "command", "test", "validation", "network", "planner", "other"]
    },
    "toolSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "label"],
      "properties": {
        "kind": {
          "$ref": "#/$defs/toolKind"
        },
        "label": {
          "allOf": [
            { "$ref": "#/$defs/safeText" },
            {
              "type": "string",
              "minLength": 1,
              "maxLength": 160
            }
          ]
        },
        "startedAt": {
          "$ref": "#/$defs/timestamp"
        },
        "elapsedMs": {
          "type": "integer",
          "minimum": 0,
          "maximum": 86400000
        }
      }
    },
    "heartbeat": {
      "type": "object",
      "additionalProperties": false,
      "required": ["lastHeartbeatAt"],
      "properties": {
        "lastHeartbeatAt": {
          "$ref": "#/$defs/timestamp"
        },
        "lastToolOutputAt": {
          "$ref": "#/$defs/timestamp"
        },
        "attempt": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100
        }
      }
    }
  }
}
