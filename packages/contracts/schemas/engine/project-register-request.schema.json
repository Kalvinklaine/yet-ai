{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.yet-ai.example/contracts/engine/project-register-request.schema.json",
  "title": "Engine Project Register Request",
  "description": "Atomically validates and registers one project using an engine-issued discovery session and opaque directory handle. A successful commit consumes the handle; failed validation creates nothing and does not consume a still-valid handle. Raw roots and client-selected project ids are not accepted.",
  "type": "object",
  "additionalProperties": false,
  "required": ["displayName", "directorySessionId", "directoryHandle"],
  "properties": {
    "displayName": { "$ref": "#/$defs/displayName" },
    "directorySessionId": { "$ref": "#/$defs/sessionId" },
    "directoryHandle": { "$ref": "#/$defs/directoryHandle" }
  },
  "$defs": {
    "sessionId": { "type": "string", "pattern": "^pds_[a-f0-9]{32}$" },
    "directoryHandle": { "type": "string", "pattern": "^dir_[a-f0-9]{32}$" },
    "displayName": { "type": "string", "minLength": 1, "maxLength": 120, "pattern": "^(?!\\s)(?![\\s\\S]*\\s$)(?![\\s\\S]*(?:[Aa][Pp][Ii][-_ ]?[Kk][Ee][Yy]|[Aa][Uu][Tt][Hh][Oo][Rr][Ii][Zz][Aa][Tt][Ii][Oo][Nn]|[Bb][Ee][Aa][Rr][Ee][Rr]|[Tt][Oo][Kk][Ee][Nn]|[Ss][Ee][Cc][Rr][Ee][Tt]|[Pp][Aa][Ss][Ss][Ww][Oo][Rr][Dd]|(?:^|[^A-Za-z0-9_-])[Ss][Kk]-(?:[Pp][Rr][Oo][Jj]-)?[A-Za-z0-9_-]{8,}|/[Uu][Ss][Ee][Rr][Ss](?:/|$)|/[Hh][Oo][Mm][Ee](?:/|$)|[A-Za-z]:(?:/|\\\\)|~(?:/|\\\\)|https?://|file:))[^\\x00-\\x1F\\x7F/\\\\]+$" }
  }
}
