{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.yet-ai.example/contracts/engine/controlled-agent-lexical-search.schema.json",
  "title": "Controlled Agent Explicit Lexical Search Metadata",
  "description": "Strict metadata contract for one explicit user-approved literal lexical search inside a controlled workspace. It grants no background indexing, hidden scan, regex, glob, broad recursive dump, private path exposure, provider/tool authority, shell, git, automatic search, or assistant-minted search authority.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "kind",
    "version",
    "authority",
    "cloudRequired",
    "executionAllowed",
    "agentStartAllowed",
    "workspace",
    "request",
    "policyFlags",
    "result"
  ],
  "properties": {
    "kind": {
      "type": "string",
      "const": "controlled_agent_lexical_search"
    },
    "version": {
      "type": "string",
      "const": "2026-07-07"
    },
    "authority": {
      "type": "string",
      "const": "explicit_literal_lexical_search_metadata"
    },
    "cloudRequired": {
      "type": "boolean",
      "const": false
    },
    "executionAllowed": {
      "type": "boolean",
      "const": false
    },
    "agentStartAllowed": {
      "type": "boolean",
      "const": false
    },
    "workspace": {
      "$ref": "#/$defs/workspace"
    },
    "request": {
      "$ref": "#/$defs/searchRequest"
    },
    "policyFlags": {
      "$ref": "#/$defs/policyFlags"
    },
    "result": {
      "$ref": "#/$defs/searchResult"
    }
  },
  "$defs": {
    "safeText": {
      "type": "string",
      "pattern": "^(?![\\s\\S]*(?:[Aa][Pp][Ii][-_ ]?[Kk][Ee][Yy]|[Aa][Uu][Tt][Hh][Oo][Rr][Ii][Zz][Aa][Tt][Ii][Oo][Nn]|[Bb][Ee][Aa][Rr][Ee][Rr]|[Cc][Oo][Oo][Kk][Ii][Ee]|[Tt][Oo][Kk][Ee][Nn]|[Ss][Ee][Cc][Rr][Ee][Tt]|[Pp][Aa][Ss][Ss][Ww][Oo][Rr][Dd]|[Rr][Aa][Ww][-_ ]?(?:[Ff][Ii][Ll][Ee]|[Bb][Oo][Dd][Yy]|[Pp][Rr][Oo][Mm][Pp][Tt]|[Cc][Oo][Mm][Mm][Aa][Nn][Dd]|[Oo][Uu][Tt][Pp][Uu][Tt]|[Ll][Oo][Gg]|[Dd][Ii][Ff][Ff]|[Pp][Aa][Yy][Ll][Oo][Aa][Dd]|[Dd][Uu][Mm][Pp])|[Ff][Ii][Ll][Ee][-_ ]?(?:[Bb][Oo][Dd][Yy]|[Cc][Oo][Nn][Tt][Ee][Nn][Tt])|[Pp][Rr][Oo][Vv][Ii][Dd][Ee][Rr](?:[-_ ]?(?:[Pp][Aa][Yy][Ll][Oo][Aa][Dd]|[Rr][Ee][Ss][Pp][Oo][Nn][Ss][Ee]))?|[Ss][Hh][Ee][Ll][Ll]|[Cc][Ww][Dd]|[Ee][Nn][Vv]|[Gg][Ii][Tt]|[Tt][Oo][Oo][Ll]|[Nn][Ee][Tt][Ww][Oo][Rr][Kk]|[Pp][Aa][Cc][Kk][Aa][Gg][Ee][-_ ]?[Ii][Nn][Ss][Tt][Aa][Ll][Ll]|[Hh][Ii][Dd][Dd][Ee][Nn][-_ ]?(?:[Ss][Cc][Aa][Nn]|[Rr][Ee][Aa][Dd]|[Ss][Ee][Aa][Rr][Cc][Hh])|[Bb][Aa][Cc][Kk][Gg][Rr][Oo][Uu][Nn][Dd][-_ ]?(?:[Ss][Cc][Aa][Nn]|[Ss][Ee][Aa][Rr][Cc][Hh])|[Ii][Nn][Dd][Ee][Xx](?:[Ii][Nn][Gg])?|[Aa][Uu][Tt][Oo][-_ ]?(?:[Ss][Ee][Aa][Rr][Cc][Hh]|[Ss][Tt][Aa][Rr][Tt]|[Aa][Pp][Pp][Ll][Yy]|[Rr][Uu][Nn]|[Vv][Ee][Rr][Ii][Ff][Yy]|[Ff][Ii][Xx]|[Rr][Ee][Pp][Aa][Ii][Rr])|(?:^|[^A-Za-z0-9_-])[Ss][Kk]-(?:[Pp][Rr][Oo][Jj]-)?[A-Za-z0-9_-]{8,}|/[Uu][Ss][Ee][Rr][Ss](?=/|$|[^A-Za-z0-9_])|/[Hh][Oo][Mm][Ee](?=/|$|[^A-Za-z0-9_])|/[Tt][Mm][Pp](?=/|$|[^A-Za-z0-9_])|/[Vv][Aa][Rr](?=/|$|[^A-Za-z0-9_])|/[Ee][Tt][Cc](?=/|$|[^A-Za-z0-9_])|/[Oo][Pp][Tt](?=/|$|[^A-Za-z0-9_])|/[Mm][Nn][Tt](?=/|$|[^A-Za-z0-9_])|/[Vv][Oo][Ll][Uu][Mm][Ee][Ss](?=/|$|[^A-Za-z0-9_])|/[Pp][Rr][Ii][Vv][Aa][Tt][Ee](?=/|$|[^A-Za-z0-9_])|[A-Za-z]:(?:/|\\\\)|~(?:/|\\\\)|[Bb][Ee][Gg][Ii][Nn] [A-Za-z ]*[Pp][Rr][Ii][Vv][Aa][Tt][Ee] [Kk][Ee][Yy]))[\\s\\S]*$"
    },
    "safeLabel": {
      "allOf": [
        {
          "$ref": "#/$defs/safeText"
        },
        {
          "type": "string",
          "minLength": 1,
          "maxLength": 120
        }
      ]
    },
    "safeSummary": {
      "allOf": [
        {
          "$ref": "#/$defs/safeText"
        },
        {
          "type": "string",
          "minLength": 1,
          "maxLength": 240
        }
      ]
    },
    "safeSnippetText": {
      "allOf": [
        {
          "$ref": "#/$defs/safeText"
        },
        {
          "type": "string",
          "minLength": 1,
          "maxLength": 600
        }
      ]
    },
    "safeId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "pattern": "^(?!assistant(?:[._:-]|$))(?!.*(?:[Aa][Ss][Ss][Ii][Ss][Tt][Aa][Nn][Tt]|[Ss][Kk]-(?:[Pp][Rr][Oo][Jj]-)?))[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "safeHash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "utcTimestamp": {
      "type": "string",
      "format": "date-time",
      "pattern": "Z$",
      "maxLength": 32
    },
    "workspaceRelativePath": {
      "type": "string",
      "minLength": 1,
      "maxLength": 180,
      "pattern": "^(?!/)(?![A-Za-z]:)(?!~)(?!.*(?:^|/)\\.)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*//)(?!.*[\\\\:*?\"<>|{}\\[\\]$^+])(?!(?:^|.*/)(?:node_modules|vendor|dist|build|out|target|coverage|__pycache__|generated|tmp|temp|secrets?|credentials?|private|public)(?:/|$))[A-Za-z0-9][A-Za-z0-9._-]*(?:/[A-Za-z0-9][A-Za-z0-9._-]*)*$"
    },
    "languageId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "pattern": "^[A-Za-z0-9_.+-]+$"
    },
    "position": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "line",
        "character"
      ],
      "properties": {
        "line": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1000000
        },
        "character": {
          "type": "integer",
          "minimum": 0,
          "maximum": 1000000
        }
      }
    },
    "range": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "start",
        "end"
      ],
      "properties": {
        "start": {
          "$ref": "#/$defs/position"
        },
        "end": {
          "$ref": "#/$defs/position"
        }
      },
      "allOf": [
        {
          "properties": {
            "end": {
              "type": "object",
              "properties": {
                "line": {
                  "type": "integer",
                  "minimum": {
                    "$data": "2/start/line"
                  }
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "start": {
                "type": "object",
                "properties": {
                  "line": true
                },
                "required": [
                  "line"
                ]
              },
              "end": {
                "type": "object",
                "properties": {
                  "line": {
                    "type": "integer",
                    "const": {
                      "$data": "2/start/line"
                    }
                  }
                },
                "required": [
                  "line"
                ]
              }
            },
            "required": [
              "start",
              "end"
            ]
          },
          "then": {
            "properties": {
              "end": {
                "type": "object",
                "properties": {
                  "character": {
                    "type": "integer",
                    "minimum": {
                      "$data": "2/start/character"
                    }
                  }
                }
              }
            }
          }
        }
      ]
    },
    "literalQuery": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120,
      "pattern": "^(?!.*(?:[\\u0000-\\u001f\\u007f-\\u009f]|[*/\\\\~]|\\.\\.|[{}[\\]()^$+?|]|[;&`$<>]|\\b(?:cwd|env|shell|git|tool|provider|model|apiKey|requestId|assistant|regex|glob|path)\\b|[Aa][Uu][Tt][Hh][Oo][Rr][Ii][Zz][Aa][Tt][Ii][Oo][Nn]|[Bb][Ee][Aa][Rr][Ee][Rr]|[Cc][Oo][Oo][Kk][Ii][Ee]|[Aa][Pp][Ii][_-]?[Kk][Ee][Yy]|[Tt][Oo][Kk][Ee][Nn]|[Ss][Ee][Cc][Rr][Ee][Tt]|[Pp][Aa][Ss][Ss][Ww][Oo][Rr][Dd]|[Pp][Rr][Ii][Vv][Aa][Tt][Ee][_-]?[Pp][Aa][Tt][Hh]|[A-Za-z]:|(?:^|[^A-Za-z0-9_-])[Ss][Kk]-(?:[Pp][Rr][Oo][Jj]-)?[A-Za-z0-9_-]{8,}))[\\s\\S]*\\S[\\s\\S]*$"
    },
    "workspace": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "controlledWorkspaceId",
        "runId",
        "workspaceMode",
        "host",
        "hostSupport",
        "privatePathExposed"
      ],
      "properties": {
        "controlledWorkspaceId": {
          "$ref": "#/$defs/safeId"
        },
        "runId": {
          "$ref": "#/$defs/safeId"
        },
        "runtimeSessionId": {
          "$ref": "#/$defs/safeId"
        },
        "workspaceMode": {
          "type": "string",
          "enum": [
            "disposable",
            "worktree",
            "existing"
          ]
        },
        "host": {
          "type": "string",
          "enum": [
            "vscode",
            "browser",
            "jetbrains"
          ]
        },
        "hostSupport": {
          "type": "string",
          "enum": [
            "vscode_supported",
            "browser_unsupported",
            "jetbrains_fail_closed"
          ]
        },
        "privatePathExposed": {
          "type": "boolean",
          "const": false
        },
        "workspaceLabel": {
          "$ref": "#/$defs/safeLabel"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "host": {
                "const": "vscode"
              }
            },
            "required": [
              "host"
            ]
          },
          "then": {
            "properties": {
              "hostSupport": {
                "const": "vscode_supported"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "host": {
                "const": "browser"
              }
            },
            "required": [
              "host"
            ]
          },
          "then": {
            "properties": {
              "hostSupport": {
                "const": "browser_unsupported"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "host": {
                "const": "jetbrains"
              }
            },
            "required": [
              "host"
            ]
          },
          "then": {
            "properties": {
              "hostSupport": {
                "const": "jetbrains_fail_closed"
              }
            }
          }
        }
      ]
    },
    "searchRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "requestId",
        "source",
        "requestIdMintedBy",
        "assistantMinted",
        "explicitUserGesture",
        "userGestureId",
        "query",
        "queryMode",
        "scope",
        "limits"
      ],
      "properties": {
        "requestId": {
          "$ref": "#/$defs/safeId"
        },
        "source": {
          "type": "string",
          "const": "gui"
        },
        "requestIdMintedBy": {
          "type": "string",
          "const": "gui"
        },
        "assistantMinted": {
          "type": "boolean",
          "const": false
        },
        "explicitUserGesture": {
          "type": "boolean",
          "const": true
        },
        "userGestureId": {
          "$ref": "#/$defs/safeId"
        },
        "query": {
          "$ref": "#/$defs/literalQuery"
        },
        "queryMode": {
          "type": "string",
          "const": "literal_text"
        },
        "scope": {
          "$ref": "#/$defs/searchScope"
        },
        "limits": {
          "$ref": "#/$defs/searchLimits"
        },
        "requestedAt": {
          "$ref": "#/$defs/utcTimestamp"
        },
        "reason": {
          "$ref": "#/$defs/safeSummary"
        }
      }
    },
    "searchScope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "controlledWorkspaceOnly",
        "includePathLabels",
        "excludeHidden",
        "excludeDependencies",
        "excludeGenerated",
        "excludeBinary",
        "excludeSecretLikePaths",
        "recursiveAllowed",
        "broadWorkspaceScanAllowed"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "const": "controlled_workspace_bounded"
        },
        "controlledWorkspaceOnly": {
          "type": "boolean",
          "const": true
        },
        "includePathLabels": {
          "type": "array",
          "minItems": 1,
          "maxItems": 8,
          "items": {
            "$ref": "#/$defs/workspaceRelativePath"
          },
          "uniqueItems": true
        },
        "excludeHidden": {
          "type": "boolean",
          "const": true
        },
        "excludeDependencies": {
          "type": "boolean",
          "const": true
        },
        "excludeGenerated": {
          "type": "boolean",
          "const": true
        },
        "excludeBinary": {
          "type": "boolean",
          "const": true
        },
        "excludeSecretLikePaths": {
          "type": "boolean",
          "const": true
        },
        "recursiveAllowed": {
          "type": "boolean",
          "const": false
        },
        "broadWorkspaceScanAllowed": {
          "type": "boolean",
          "const": false
        }
      }
    },
    "searchLimits": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "maxFilesScanned",
        "maxMatches",
        "maxSnippetBytes",
        "maxTotalSnippetBytes",
        "literalOnly",
        "regexAllowed",
        "globAllowed",
        "pathQueryAllowed",
        "indexingAllowed",
        "backgroundAllowed"
      ],
      "properties": {
        "maxFilesScanned": {
          "type": "integer",
          "minimum": 1,
          "maximum": 200
        },
        "maxMatches": {
          "type": "integer",
          "minimum": 0,
          "maximum": 20
        },
        "maxSnippetBytes": {
          "type": "integer",
          "minimum": 1,
          "maximum": 600
        },
        "maxTotalSnippetBytes": {
          "type": "integer",
          "minimum": 1,
          "maximum": 4000
        },
        "literalOnly": {
          "type": "boolean",
          "const": true
        },
        "regexAllowed": {
          "type": "boolean",
          "const": false
        },
        "globAllowed": {
          "type": "boolean",
          "const": false
        },
        "pathQueryAllowed": {
          "type": "boolean",
          "const": false
        },
        "indexingAllowed": {
          "type": "boolean",
          "const": false
        },
        "backgroundAllowed": {
          "type": "boolean",
          "const": false
        },
        "limitLabel": {
          "$ref": "#/$defs/safeLabel"
        }
      }
    },
    "policyFlags": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "explicitLiteralSearchAllowed",
        "hiddenSearchAllowed",
        "backgroundSearchAllowed",
        "indexingAllowed",
        "regexAllowed",
        "globAllowed",
        "pathQueryAllowed",
        "broadWorkspaceScanAllowed",
        "fileReadBodyAllowed",
        "fileWriteAllowed",
        "shellAllowed",
        "gitAllowed",
        "providerAllowed",
        "toolAllowed",
        "autoSearchAllowed",
        "autoApplyAllowed",
        "autoRunAllowed"
      ],
      "properties": {
        "explicitLiteralSearchAllowed": {
          "type": "boolean"
        },
        "hiddenSearchAllowed": {
          "type": "boolean",
          "const": false
        },
        "backgroundSearchAllowed": {
          "type": "boolean",
          "const": false
        },
        "indexingAllowed": {
          "type": "boolean",
          "const": false
        },
        "regexAllowed": {
          "type": "boolean",
          "const": false
        },
        "globAllowed": {
          "type": "boolean",
          "const": false
        },
        "pathQueryAllowed": {
          "type": "boolean",
          "const": false
        },
        "broadWorkspaceScanAllowed": {
          "type": "boolean",
          "const": false
        },
        "fileReadBodyAllowed": {
          "type": "boolean",
          "const": false
        },
        "fileWriteAllowed": {
          "type": "boolean",
          "const": false
        },
        "shellAllowed": {
          "type": "boolean",
          "const": false
        },
        "gitAllowed": {
          "type": "boolean",
          "const": false
        },
        "providerAllowed": {
          "type": "boolean",
          "const": false
        },
        "toolAllowed": {
          "type": "boolean",
          "const": false
        },
        "autoSearchAllowed": {
          "type": "boolean",
          "const": false
        },
        "autoApplyAllowed": {
          "type": "boolean",
          "const": false
        },
        "autoRunAllowed": {
          "type": "boolean",
          "const": false
        }
      }
    },
    "snippet": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "pathLabel",
        "range",
        "languageId",
        "snippet",
        "snippetByteCount",
        "snippetHash",
        "matchCount",
        "truncated"
      ],
      "properties": {
        "pathLabel": {
          "$ref": "#/$defs/workspaceRelativePath"
        },
        "range": {
          "$ref": "#/$defs/range"
        },
        "languageId": {
          "$ref": "#/$defs/languageId"
        },
        "snippet": {
          "$ref": "#/$defs/safeSnippetText"
        },
        "snippetByteCount": {
          "type": "integer",
          "minimum": 1,
          "maximum": 600
        },
        "snippetHash": {
          "$ref": "#/$defs/safeHash"
        },
        "matchCount": {
          "type": "integer",
          "minimum": 1,
          "maximum": 20
        },
        "truncated": {
          "type": "boolean"
        }
      }
    },
    "searchResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "cloudRequired",
        "searchAllowed",
        "privatePathExposed",
        "rawContentIncluded",
        "resultCount",
        "totalMatchCount",
        "totalSnippetBytes",
        "truncated",
        "resultHash",
        "snippets",
        "message"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "disabled",
            "blocked",
            "succeeded",
            "truncated"
          ]
        },
        "cloudRequired": {
          "type": "boolean",
          "const": false
        },
        "searchAllowed": {
          "type": "boolean"
        },
        "privatePathExposed": {
          "type": "boolean",
          "const": false
        },
        "rawContentIncluded": {
          "type": "boolean",
          "const": false
        },
        "resultCount": {
          "type": "integer",
          "minimum": 0,
          "maximum": 20
        },
        "totalMatchCount": {
          "type": "integer",
          "minimum": 0,
          "maximum": 200
        },
        "totalSnippetBytes": {
          "type": "integer",
          "minimum": 0,
          "maximum": 4000
        },
        "truncated": {
          "type": "boolean"
        },
        "resultHash": {
          "$ref": "#/$defs/safeHash"
        },
        "snippets": {
          "type": "array",
          "minItems": 0,
          "maxItems": 20,
          "items": {
            "$ref": "#/$defs/snippet"
          }
        },
        "blockedReason": {
          "type": "string",
          "enum": [
            "search_disabled",
            "policy_denied",
            "unsupported_host",
            "unsafe_query",
            "unsafe_scope",
            "outside_workspace",
            "hidden_path",
            "dependency_path",
            "generated_path",
            "binary_file",
            "secret_like_path",
            "budget_exceeded",
            "assistant_minted"
          ]
        },
        "message": {
          "$ref": "#/$defs/safeSummary"
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "workspace": {
            "type": "object",
            "properties": {
              "host": {
                "const": "vscode"
              }
            },
            "required": [
              "host"
            ]
          }
        },
        "required": [
          "workspace"
        ]
      },
      "then": {
        "properties": {
          "policyFlags": {
            "type": "object",
            "properties": {
              "explicitLiteralSearchAllowed": {
                "const": true
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "workspace": {
            "type": "object",
            "properties": {
              "host": {
                "enum": [
                  "browser",
                  "jetbrains"
                ]
              }
            },
            "required": [
              "host"
            ]
          }
        },
        "required": [
          "workspace"
        ]
      },
      "then": {
        "properties": {
          "policyFlags": {
            "type": "object",
            "properties": {
              "explicitLiteralSearchAllowed": {
                "const": false
              }
            }
          },
          "result": {
            "type": "object",
            "properties": {
              "status": {
                "enum": [
                  "disabled",
                  "blocked"
                ]
              },
              "searchAllowed": {
                "const": false
              },
              "blockedReason": {}
            },
            "required": [
              "blockedReason"
            ]
