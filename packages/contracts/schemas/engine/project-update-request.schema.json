{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.yet-ai.example/contracts/engine/project-update-request.schema.json",
  "title": "Engine Project Update Request",
  "description": "Updates only the safe display name when expectedRevision matches. Project identity is URL-owned.",
  "type": "object",
  "additionalProperties": false,
  "required": ["displayName", "expectedRevision"],
  "properties": {
    "displayName": { "type": "string", "minLength": 1, "maxLength": 120, "pattern": "^(?!\\s)(?![\\s\\S]*\\s$)(?![\\s\\S]*(?:[Aa][Pp][Ii][-_ ]?[Kk][Ee][Yy]|[Aa][Uu][Tt][Hh][Oo][Rr][Ii][Zz][Aa][Tt][Ii][Oo][Nn]|[Bb][Ee][Aa][Rr][Ee][Rr]|[Tt][Oo][Kk][Ee][Nn]|[Ss][Ee][Cc][Rr][Ee][Tt]|[Pp][Aa][Ss][Ss][Ww][Oo][Rr][Dd]|(?:^|[^A-Za-z0-9_-])[Ss][Kk]-(?:[Pp][Rr][Oo][Jj]-)?[A-Za-z0-9_-]{8,}|/[Uu][Ss][Ee][Rr][Ss](?:/|$)|/[Hh][Oo][Mm][Ee](?:/|$)|[A-Za-z]:(?:/|\\\\)|~(?:/|\\\\)|https?://|file:))[^\\x00-\\x1F\\x7F/\\\\]+$" },
    "expectedRevision": { "type": "string", "pattern": "^(?:0|[1-9][0-9]{0,19})$" }
  }
}
