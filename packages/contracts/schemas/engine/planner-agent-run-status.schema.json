{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.yet-ai.example/contracts/engine/planner-agent-run-status.schema.json",
  "title": "Planner Agent Run Status Snapshot",
  "description": "Future/simulator-facing sanitized scheduler snapshot for one delegated agent run. It contains no prompts, provider responses, tokens, auth codes, cookies, private paths, or workspace file contents.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "protocolVersion",
    "agentRunId",
    "cardId",
    "poolId",
    "autonomousMode",
    "status",
    "nextAction",
    "observedAt"
  ],
  "properties": {
    "protocolVersion": {
      "type": "string",
      "const": "2026-05-15"
    },
    "agentRunId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.-]{0,127}$"
    },
    "cardId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_-]{0,63}$"
    },
    "poolId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 96,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_-]{0,95}$"
    },
    "autonomousMode": {
      "type": "boolean"
    },
    "status": {
      "type": "string",
      "enum": [
        "running",
        "done",
        "failed",
        "stuck",
        "unknown"
      ]
    },
    "nextAction": {
      "type": "string",
      "enum": [
        "check_agents",
        "merge_completed",
        "verify_merge",
        "spawn_ready",
        "recover_failed",
        "plan_next_pool",
        "idle_blocked"
      ]
    },
    "idleReason": {
      "type": "string",
      "enum": [
        "waiting_for_user_decision",
        "waiting_for_external_dependency",
        "concurrency_limit_reached",
        "blocked_by_failed_verification",
        "blocked_by_policy",
        "all_work_closed",
        "autonomy_not_permitted"
      ]
    },
    "observedAt": {
      "type": "string",
      "format": "date-time"
    },
    "lastHeartbeatAt": {
      "type": "string",
      "format": "date-time"
    },
    "completedAt": {
      "type": "string",
      "format": "date-time"
    },
    "failureKind": {
      "type": "string",
      "enum": [
        "agent_error",
        "verification_failed",
        "timeout",
        "heartbeat_expired",
        "unknown"
      ]
    },
    "safeSummary": {
      "$ref": "#/$defs/safeSummary"
    },
    "overflowRecovery": {
      "$ref": "#/$defs/overflowRecovery"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "nextAction": {
            "const": "idle_blocked"
          }
        },
        "required": [
          "nextAction"
        ]
      },
      "then": {
        "properties": {
          "idleReason": true
        },
        "required": [
          "idleReason"
        ]
      },
      "else": {
        "not": {
          "required": [
            "idleReason"
          ]
        }
      }
    },
    {
      "if": {
        "properties": {
          "status": {
            "enum": [
              "failed",
              "stuck"
            ]
          }
        },
        "required": [
          "status"
        ]
      },
      "then": {
        "properties": {
          "failureKind": true
        },
        "required": [
          "failureKind"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "overflowRecovery": true
        },
        "required": [
          "overflowRecovery"
        ]
      },
      "then": {
        "properties": {
          "status": {
            "enum": [
              "failed",
              "stuck"
            ]
          },
          "nextAction": {
            "const": "recover_failed"
          }
        },
        "required": [
          "status",
          "nextAction"
        ]
      }
    }
  ],
  "$defs": {
    "safeText": {
      "type": "string",
      "pattern": "^(?![\\s\\S]*(?:[aA][pP][iI][-_ ]?[kK][eE][yY]|[aA][uU][tT][hH][oO][rR][iI][zZ][aA][tT][iI][oO][nN]|[bB][eE][aA][rR][eE][rR]|[tT][oO][kK][eE][nN]|[sS][eE][cC][rR][eE][tT]|[pP][aA][sS][sS][wW][oO][rR][dD]|[cC][oO][oO][kK][iI][eE]|[pP][kK][cC][eE]|[rR][eE][fF][rR][eE][sS][hH]|[aA][cC][cC][eE][sS][sS][-_ ]?[tT][oO][kK][eE][nN]|[aA][uU][tT][hH][-_ ]?[cC][oO][dD][eE]|[cC][hH][aA][iI][nN][-_ ]?[oO][fF][-_ ]?[tT][hH][oO][uU][gG][hH][tT]|[rR][aA][wW][-_ ]?(?:[pP][rR][oO][mM][pP][tT]|[dD][uU][mM][pP]|[oO][uU][tT][pP][uU][tT]|[fF][iI][lL][eE]|[wW][oO][rR][kK][sS][pP][aA][cC][eE])|[pP][rR][oO][vV][iI][dD][eE][rR][-_ ]?(?:[rR][eE][sS][pP][oO][nN][sS][eE]|[bB][oO][dD][yY])|[cC][rR][eE][dD][eE][nN][tT][iI][aA][lL]|[fF][iI][lL][eE][-_ ]?[cC][oO][nN][tT][eE][nN][tT]|[wW][oO][rR][kK][sS][pP][aA][cC][eE][-_ ]?(?:[fF][iI][lL][eE]|[cC][oO][nN][tT][eE][nN][tT])|/Users/|/home/|/private/|[A-Za-z]:\\\\|~/|\\.[cC][oO][dD][eE][xX]/[aA][uU][tT][hH]\\.json|(?:[aA][uU][tT][hH]|[cC][rR][eE][dD][eE][nN][tT][iI][aA][lL][sS]?)\\.json|BEGIN [A-Z ]*PRIVATE KEY))[\\s\\S]*$"
    },
    "safeSummary": {
      "allOf": [
        {
          "$ref": "#/$defs/safeText"
        },
        {
          "type": "string",
          "minLength": 1,
          "maxLength": 512
        }
      ]
    },
    "safeOverflowMessage": {
      "allOf": [
        {
          "$ref": "#/$defs/safeText"
        },
        {
          "type": "string",
          "minLength": 1,
          "maxLength": 320
        }
      ]
    },
    "overflowRecoveryKind": {
      "type": "string",
      "enum": [
        "context_length_exceeded",
        "tool_output_too_large",
        "task_board_output_too_large"
      ]
    },
    "overflowRecovery": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "message"
      ],
      "properties": {
        "kind": {
          "$ref": "#/$defs/overflowRecoveryKind"
        },
        "message": {
          "$ref": "#/$defs/safeOverflowMessage"
        },
        "retryable": {
          "type": "boolean"
        }
      }
    }
  }
}
