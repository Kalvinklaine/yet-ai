{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.yet-ai.example/contracts/engine/manual-runner-plan-proposal.schema.json",
  "title": "Manual Runner Plan Proposal",
  "description": "Display-only manual runner plan proposal with bounded sanitized labels for the visible user-driven runner v2 loop. It is inert and excludes commands, shell, git, tools, provider data, file contents, patches, apply requests, verification requests, hidden reads, and auto-run or auto-apply flags.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "protocolVersion",
    "kind",
    "title",
    "steps",
    "rationale",
    "nextAction"
  ],
  "properties": {
    "protocolVersion": {
      "type": "string",
      "const": "2026-05-29"
    },
    "kind": {
      "type": "string",
      "const": "manual_runner_plan_proposal"
    },
    "title": {
      "$ref": "#/$defs/title"
    },
    "steps": {
      "type": "array",
      "description": "One to six user-visible manual step labels only; these are not executable instructions.",
      "minItems": 1,
      "maxItems": 6,
      "items": {
        "$ref": "#/$defs/label"
      }
    },
    "rationale": {
      "$ref": "#/$defs/rationale"
    },
    "nextAction": {
      "$ref": "#/$defs/label"
    }
  },
  "$defs": {
    "safePlanText": {
      "type": "string",
      "pattern": "^(?![\\s\\S]*(?:[aA][pP][iI][-_ ]?[kK][eE][yY]|[aA][uU][tT][hH][oO][rR][iI][zZ][aA][tT][iI][oO][nN]|[bB][eE][aA][rR][eE][rR]|[tT][oO][kK][eE][nN]|[sS][eE][cC][rR][eE][tT]|[pP][aA][sS][sS][wW][oO][rR][dD]|[cC][oO][oO][kK][iI][eE]|[pP][kK][cC][eE]|[rR][eE][fF][rR][eE][sS][hH]|[aA][cC][cC][eE][sS][sS][-_ ]?[tT][oO][kK][eE][nN]|[aA][uU][tT][hH][-_ ]?[cC][oO][dD][eE]|[cC][hH][aA][iI][nN][-_ ]?[oO][fF][-_ ]?[tT][hH][oO][uU][gG][hH][tT]|[rR][aA][wW][-_ ]?(?:[pP][rR][oO][mM][pP][tT]|[cC][oO][mM][mM][aA][nN][dD]|[dD][uU][mM][pP]|[oO][uU][tT][pP][uU][tT]|[fF][iI][lL][eE]|[wW][oO][rR][kK][sS][pP][aA][cC][eE])|[pP][rR][oO][vV][iI][dD][eE][rR][-_ ]?(?:[rR][eE][sS][pP][oO][nN][sS][eE]|[bB][oO][dD][yY])|[cC][rR][eE][dD][eE][nN][tT][iI][aA][lL]|[fF][iI][lL][eE][-_ ]?[cC][oO][nN][tT][eE][nN][tT]|[wW][oO][rR][kK][sS][pP][aA][cC][eE][-_ ]?(?:[fF][iI][lL][eE]|[cC][oO][nN][tT][eE][nN][tT])|[sS][hH][eE][lL][lL]|[gG][iI][tT]|[tT][oO][oO][lL]|[tT][aA][sS][kK]|[pP][aA][tT][cC][hH]|[aA][pP][pP][lL][yY]|[eE][xX][eE][cC]|[cC][mM][dD]|[cC][oO][mM][mM][aA][nN][dD]|[aA][uU][tT][oO][-_ ]?[rR][uU][nN]|[hH][iI][dD][dD][eE][nN][-_ ]?[rR][eE][aA][dD]|[nN][pP][mM]\\s+[rR][uU][nN]|[cC][aA][rR][gG][oO]\\s+(?:[cC][hH][eE][cC][kK]|[tT][eE][sS][tT])|(?:^|[^A-Za-z0-9_-])[Ss][Kk]-(?:[Pp][Rr][Oo][Jj]-)?[A-Za-z0-9_-]{8,}|/[Uu][Ss][Ee][Rr][Ss](?=/|$|[^A-Za-z0-9_])|/[Hh][Oo][Mm][Ee](?=/|$|[^A-Za-z0-9_])|/[Tt][Mm][Pp](?=/|$|[^A-Za-z0-9_])|/[Ee][Tt][Cc](?=/|$|[^A-Za-z0-9_])|/[Oo][Pp][Tt](?=/|$|[^A-Za-z0-9_])|/[Mm][Nn][Tt](?=/|$|[^A-Za-z0-9_])|/[Vv][Aa][Rr](?=/|$|[^A-Za-z0-9_])|/[Vv][Oo][Ll][Uu][Mm][Ee][Ss](?=/|$|[^A-Za-z0-9_])|/[Pp][Rr][Ii][Vv][Aa][Tt][Ee](?=/|$|[^A-Za-z0-9_])|[A-Za-z]:(?:/|\\\\)|~/|\\.[cC][oO][dD][eE][xX]/[aA][uU][tT][hH]\\.json|(?:[aA][uU][tT][hH]|[cC][rR][eE][dD][eE][nN][tT][iI][aA][lL][sS]?)\\.json|[Bb][Ee][Gg][Ii][Nn] [A-Za-z ]*[Pp][Rr][Ii][Vv][Aa][Tt][Ee] [Kk][Ee][Yy]))[\\s\\S]*$"
    },
    "title": {
      "allOf": [
        {
          "$ref": "#/$defs/safePlanText"
        },
        {
          "type": "string",
          "minLength": 1,
          "maxLength": 80
        }
      ]
    },
    "label": {
      "allOf": [
        {
          "$ref": "#/$defs/safePlanText"
        },
        {
          "type": "string",
          "minLength": 1,
          "maxLength": 140
        }
      ]
    },
    "rationale": {
      "allOf": [
        {
          "$ref": "#/$defs/safePlanText"
        },
        {
          "type": "string",
          "minLength": 1,
          "maxLength": 280
        }
      ]
    }
  }
}
