{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.yet-ai.example/contracts/engine/agent-progress-list-response.schema.json",
  "title": "Agent Progress List Response",
  "description": "Read-only local engine-owned planner/agent progress list response with bounded sanitized snapshots only. It does not require cloud access, represents missing local progress state as an empty list, and excludes source metadata, prompts, chain-of-thought, raw provider responses, secrets, private paths, credential paths, and workspace file contents.",
  "type": "object",
  "additionalProperties": false,
  "required": ["cloudRequired", "providerAccess", "snapshots"],
  "properties": {
    "cloudRequired": {
      "type": "boolean",
      "const": false
    },
    "providerAccess": {
      "type": "string",
      "const": "direct"
    },
    "generatedAt": {
      "$ref": "#/$defs/timestamp"
    },
    "snapshots": {
      "type": "array",
      "maxItems": 50,
      "items": {
        "$ref": "#/$defs/snapshot"
      }
    }
  },
  "$defs": {
    "snapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": ["protocolVersion", "runId", "cardId", "startedAt", "updatedAt", "phase", "status", "message", "elapsedMs", "ageMs", "recentEvents"],
      "allOf": [
        {
          "if": {
            "properties": {
              "overflowRecovery": true
            },
            "required": ["overflowRecovery"]
          },
          "then": {
            "properties": {
              "phase": {
                "not": {
                  "const": "done"
                }
              },
              "status": {
                "enum": ["failed", "stuck", "stalled"]
              }
            }
          }
        }
      ],
      "properties": {
        "protocolVersion": {
          "type": "string",
          "const": "2026-05-29"
        },
        "runId": {
          "$ref": "#/$defs/id"
        },
        "cardId": {
          "$ref": "#/$defs/cardId"
        },
        "startedAt": {
          "$ref": "#/$defs/timestamp"
        },
        "updatedAt": {
          "$ref": "#/$defs/timestamp"
        },
        "completedAt": {
          "$ref": "#/$defs/timestamp"
        },
        "phase": {
          "$ref": "#/$defs/phase"
        },
        "status": {
          "$ref": "#/$defs/status"
        },
        "message": {
          "$ref": "#/$defs/safeMessage"
        },
        "elapsedMs": {
          "$ref": "#/$defs/durationMs"
        },
        "ageMs": {
          "$ref": "#/$defs/durationMs"
        },
        "lastHeartbeatAt": {
          "$ref": "#/$defs/timestamp"
        },
        "heartbeatAgeMs": {
          "$ref": "#/$defs/durationMs"
        },
        "lastToolOutputAt": {
          "$ref": "#/$defs/timestamp"
        },
        "toolOutputAgeMs": {
          "$ref": "#/$defs/durationMs"
        },
        "currentTool": {
          "$ref": "#/$defs/toolSummary"
        },
        "outputTail": {
          "$ref": "#/$defs/outputTail"
        },
        "stuckReason": {
          "type": "string",
          "enum": ["heartbeat_timeout", "tool_output_timeout", "explicit_failure", "explicit_stuck", "none"]
        },
        "overflowRecovery": {
          "$ref": "#/$defs/overflowRecovery"
        },
        "recentEvents": {
          "type": "array",
          "maxItems": 20,
          "items": {
            "$ref": "#/$defs/recentEvent"
          }
        }
      }
    },
    "id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^(?!.*(?:[Aa][Uu][Tt][Hh][Oo][Rr][Ii][Zz][Aa][Tt][Ii][Oo][Nn]|[Bb][Ee][Aa][Rr][Ee][Rr]|[Aa][Pp][Ii][-_]?[Kk][Ee][Yy]|[Tt][Oo][Kk][Ee][Nn]|[Ss][Ee][Cc][Rr][Ee][Tt]|[Aa][Cc][Cc][Ee][Ss][Ss][-_]?[Tt][Oo][Kk][Ee][Nn]|sk-(?:proj-)?[A-Za-z0-9_-]{8,}))[A-Za-z0-9][A-Za-z0-9_.-]{0,127}$"
    },
    "cardId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "pattern": "^(?!.*(?:[Aa][Uu][Tt][Hh][Oo][Rr][Ii][Zz][Aa][Tt][Ii][Oo][Nn]|[Bb][Ee][Aa][Rr][Ee][Rr]|[Aa][Pp][Ii][-_]?[Kk][Ee][Yy]|[Tt][Oo][Kk][Ee][Nn]|[Ss][Ee][Cc][Rr][Ee][Tt]|[Aa][Cc][Cc][Ee][Ss][Ss][-_]?[Tt][Oo][Kk][Ee][Nn]|sk-(?:proj-)?[A-Za-z0-9_-]{8,}))[A-Za-z0-9][A-Za-z0-9_-]{0,63}$"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "minLength": 20,
      "maxLength": 32,
      "pattern": "Z$"
    },
    "durationMs": {
      "type": "integer",
      "minimum": 0,
      "maximum": 604800000
    },
    "phase": {
      "type": "string",
      "enum": ["queued", "started", "reading_context", "editing", "running_command", "waiting_for_tool", "verifying", "finishing", "done", "failed", "stuck"]
    },
    "status": {
      "type": "string",
      "enum": ["pending", "running", "healthy_running", "long_running", "stalled", "stuck", "done", "failed"]
    },
    "safeText": {
      "type": "string",
      "pattern": "^(?![\\s\\S]*(?:[aA][pP][iI][-_ ]?[kK][eE][yY]|[aA][uU][tT][hH][oO][rR][iI][zZ][aA][tT][iI][oO][nN]|[bB][eE][aA][rR][eE][rR]|[tT][oO][kK][eE][nN]|[sS][eE][cC][rR][eE][tT]|[pP][aA][sS][sS][wW][oO][rR][dD]|[cC][oO][oO][kK][iI][eE]|[pP][kK][cC][eE]|[rR][eE][fF][rR][eE][sS][hH]|[aA][cC][cC][eE][sS][sS][-_ ]?[tT][oO][kK][eE][nN]|[aA][uU][tT][hH][-_ ]?[cC][oO][dD][eE]|[cC][hH][aA][iI][nN][-_ ]?[oO][fF][-_ ]?[tT][hH][oO][uU][gG][hH][tT]|[rR][aA][wW][-_ ]?(?:[pP][rR][oO][mM][pP][tT]|[dD][uU][mM][pP]|[oO][uU][tT][pP][uU][tT]|[fF][iI][lL][eE]|[wW][oO][rR][kK][sS][pP][aA][cC][eE])|[pP][rR][oO][vV][iI][dD][eE][rR][-_ ]?(?:[rR][eE][sS][pP][oO][nN][sS][eE]|[bB][oO][dD][yY])|[cC][rR][eE][dD][eE][nN][tT][iI][aA][lL]|[fF][iI][lL][eE][-_ ]?[cC][oO][nN][tT][eE][nN][tT]|[wW][oO][rR][kK][sS][pP][aA][cC][eE][-_ ]?(?:[fF][iI][lL][eE]|[cC][oO][nN][tT][eE][nN][tT])|/[Uu][Ss][Ee][Rr][Ss]/|/[Hh][Oo][Mm][Ee]/|/[Tt][Mm][Pp]/|/[Vv][Aa][Rr]/|/[Vv][Oo][Ll][Uu][Mm][Ee][Ss]/|/[Pp][Rr][Ii][Vv][Aa][Tt][Ee]/|[A-Za-z]:\\\\|~/|\\.[cC][oO][dD][eE][xX]/[aA][uU][tT][hH]\\.json|(?:[aA][uU][tT][hH]|[cC][rR][eE][dD][eE][nN][tT][iI][aA][lL][sS]?)\\.json|BEGIN [A-Z ]*PRIVATE KEY))[\\s\\S]*$"
    },
    "safeMessage": {
      "allOf": [
        { "$ref": "#/$defs/safeText" },
        {
          "type": "string",
          "minLength": 1,
          "maxLength": 280
        }
      ]
    },
    "outputTail": {
      "allOf": [
        { "$ref": "#/$defs/safeText" },
        {
          "type": "string",
          "maxLength": 2000
        }
      ]
    },
    "safeOverflowMessage": {
      "allOf": [
        { "$ref": "#/$defs/safeText" },
        {
          "type": "string",
          "minLength": 1,
          "maxLength": 320
        }
      ]
    },
    "overflowRecoveryKind": {
      "type": "string",
      "enum": [
        "context_length_exceeded",
        "tool_output_too_large",
        "task_board_output_too_large"
      ]
    },
    "overflowRecovery": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "message"],
      "properties": {
        "kind": {
          "$ref": "#/$defs/overflowRecoveryKind"
        },
        "message": {
          "$ref": "#/$defs/safeOverflowMessage"
        },
        "retryable": {
          "type": "boolean"
        }
      }
    },
    "toolKind": {
      "type": "string",
      "enum": ["read", "edit", "command", "test", "validation", "network", "planner", "other"]
    },
    "toolSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "label"],
      "properties": {
        "kind": {
          "$ref": "#/$defs/toolKind"
        },
        "label": {
          "allOf": [
            { "$ref": "#/$defs/safeText" },
            {
              "type": "string",
              "minLength": 1,
              "maxLength": 160
            }
          ]
        },
        "startedAt": {
          "$ref": "#/$defs/timestamp"
        },
        "elapsedMs": {
          "type": "integer",
          "minimum": 0,
          "maximum": 86400000
        }
      }
    },
    "recentEvent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["eventId", "timestamp", "phase", "status", "message"],
      "properties": {
        "eventId": {
          "$ref": "#/$defs/id"
        },
        "timestamp": {
          "$ref": "#/$defs/timestamp"
        },
        "phase": {
          "$ref": "#/$defs/phase"
        },
        "status": {
          "$ref": "#/$defs/status"
        },
        "message": {
          "$ref": "#/$defs/safeMessage"
        }
      }
    }
  }
}
