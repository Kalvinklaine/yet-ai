{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.yet-ai.example/contracts/engine/controlled-agent-run-state.schema.json",
  "title": "Controlled Agent Run State Metadata",
  "description": "Strict metadata-only Sprint 76 controlled-agent run state skeleton. It records deterministic state, workspace-readiness correlation, bounded limits, counters, stop metadata, and sanitized details, but grants no auto-start, shell, git, provider, tool, file, command, edit, verification, repair, rollback, runtime, bridge, or execution authority.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "kind",
    "version",
    "authority",
    "cloudRequired",
    "executionAllowed",
    "agentStartAllowed",
    "autoStartAllowed",
    "workspace",
    "request",
    "phase",
    "limits",
    "counters",
    "policyFlags",
    "details"
  ],
  "properties": {
    "kind": {
      "type": "string",
      "const": "controlled_agent_run_state"
    },
    "version": {
      "type": "string",
      "const": "2026-06-29"
    },
    "authority": {
      "type": "string",
      "const": "state_metadata_only"
    },
    "cloudRequired": {
      "type": "boolean",
      "const": false
    },
    "executionAllowed": {
      "type": "boolean",
      "const": false
    },
    "agentStartAllowed": {
      "type": "boolean",
      "const": false
    },
    "autoStartAllowed": {
      "type": "boolean",
      "const": false
    },
    "workspace": {
      "$ref": "#/$defs/workspace"
    },
    "request": {
      "$ref": "#/$defs/runRequest"
    },
    "phase": {
      "$ref": "#/$defs/phase"
    },
    "limits": {
      "$ref": "#/$defs/limits"
    },
    "counters": {
      "$ref": "#/$defs/counters"
    },
    "policyFlags": {
      "$ref": "#/$defs/policyFlags"
    },
    "stop": {
      "$ref": "#/$defs/stop"
    },
    "details": {
      "$ref": "#/$defs/details"
    }
  },
  "$defs": {
    "safeText": {
      "type": "string",
      "pattern": "^(?![\\s\\S]*(?:[Aa][Pp][Ii][-_ ]?[Kk][Ee][Yy]|[Aa][Uu][Tt][Hh][Oo][Rr][Ii][Zz][Aa][Tt][Ii][Oo][Nn]|[Bb][Ee][Aa][Rr][Ee][Rr]|[Cc][Oo][Oo][Kk][Ii][Ee]|[Tt][Oo][Kk][Ee][Nn]|[Ss][Ee][Cc][Rr][Ee][Tt]|[Pp][Aa][Ss][Ss][Ww][Oo][Rr][Dd]|[Rr][Aa][Ww][-_ ]?(?:[Ff][Ii][Ll][Ee]|[Pp][Rr][Oo][Mm][Pp][Tt]|[Cc][Oo][Mm][Mm][Aa][Nn][Dd]|[Oo][Uu][Tt][Pp][Uu][Tt]|[Ll][Oo][Gg]|[Dd][Ii][Ff][Ff])|[Ff][Ii][Ll][Ee][-_ ]?(?:[Bb][Oo][Dd][Yy]|[Cc][Oo][Nn][Tt][Ee][Nn][Tt])|[Pp][Rr][Oo][Vv][Ii][Dd][Ee][Rr]|[Ss][Hh][Ee][Ll][Ll]|[Cc][Oo][Mm][Mm][Aa][Nn][Dd]|[Cc][Ww][Dd]|[Ee][Nn][Vv]|[Gg][Ii][Tt]|[Tt][Oo][Oo][Ll]|[Nn][Ee][Tt][Ww][Oo][Rr][Kk]|[Pp][Aa][Cc][Kk][Aa][Gg][Ee][-_ ]?[Ii][Nn][Ss][Tt][Aa][Ll][Ll]|[Hh][Ii][Dd][Dd][Ee][Nn][-_ ]?(?:[Ss][Cc][Aa][Nn]|[Rr][Ee][Aa][Dd]|[Ss][Ee][Aa][Rr][Cc][Hh])|[Ii][Nn][Dd][Ee][Xx](?:[Ii][Nn][Gg])?|[Aa][Uu][Tt][Oo][-_ ]?(?:[Ss][Tt][Aa][Rr][Tt]|[Aa][Pp][Pp][Ll][Yy]|[Rr][Uu][Nn]|[Vv][Ee][Rr][Ii][Ff][Yy]|[Ff][Ii][Xx]|[Rr][Ee][Pp][Aa][Ii][Rr])|(?:^|[^A-Za-z0-9_-])[Ss][Kk]-(?:[Pp][Rr][Oo][Jj]-)?[A-Za-z0-9_-]{8,}|/[Uu][Ss][Ee][Rr][Ss](?=/|$|[^A-Za-z0-9_])|/[Hh][Oo][Mm][Ee](?=/|$|[^A-Za-z0-9_])|/[Tt][Mm][Pp](?=/|$|[^A-Za-z0-9_])|/[Vv][Aa][Rr](?=/|$|[^A-Za-z0-9_])|/[Ee][Tt][Cc](?=/|$|[^A-Za-z0-9_])|/[Oo][Pp][Tt](?=/|$|[^A-Za-z0-9_])|/[Mm][Nn][Tt](?=/|$|[^A-Za-z0-9_])|/[Vv][Oo][Ll][Uu][Mm][Ee][Ss](?=/|$|[^A-Za-z0-9_])|/[Pp][Rr][Ii][Vv][Aa][Tt][Ee](?=/|$|[^A-Za-z0-9_])|[A-Za-z]:(?:/|\\\\)|~(?:/|\\\\)|[Bb][Ee][Gg][Ii][Nn] [A-Za-z ]*[Pp][Rr][Ii][Vv][Aa][Tt][Ee] [Kk][Ee][Yy]))[\\s\\S]*$"
    },
    "safeLabel": {
      "allOf": [
        { "$ref": "#/$defs/safeText" },
        { "type": "string", "minLength": 1, "maxLength": 100 }
      ]
    },
    "safeSummary": {
      "allOf": [
        { "$ref": "#/$defs/safeText" },
        { "type": "string", "minLength": 1, "maxLength": 240 }
      ]
    },
    "safeId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80,
      "pattern": "^(?!assistant(?:[._-]|$))(?!.*(?:[Aa][Ss][Ss][Ii][Ss][Tt][Aa][Nn][Tt]|[Ss][Kk]-(?:[Pp][Rr][Oo][Jj]-)?))[A-Za-z0-9][A-Za-z0-9._-]*$"
    },
    "utcTimestamp": {
      "type": "string",
      "format": "date-time",
      "pattern": "Z$",
      "maxLength": 32
    },
    "workspace": {
      "type": "object",
      "additionalProperties": false,
      "required": ["controlledWorkspaceId", "runId", "readinessId", "workspaceMode", "host", "workspaceReady", "privatePathExposed"],
      "properties": {
        "controlledWorkspaceId": { "$ref": "#/$defs/safeId" },
        "runId": { "$ref": "#/$defs/safeId" },
        "readinessId": { "$ref": "#/$defs/safeId" },
        "workspaceMode": {
          "type": "string",
          "enum": ["disposable", "worktree", "existing"]
        },
        "host": {
          "type": "string",
          "enum": ["vscode", "jetbrains"]
        },
        "workspaceReady": {
          "type": "boolean"
        },
        "privatePathExposed": {
          "type": "boolean",
          "const": false
        },
        "workspaceLabel": { "$ref": "#/$defs/safeLabel" }
      }
    },
    "runRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["requestId", "source", "requestIdMintedBy", "assistantMinted", "correlation"],
      "properties": {
        "requestId": { "$ref": "#/$defs/safeId" },
        "source": {
          "type": "string",
          "enum": ["gui", "host"]
        },
        "requestIdMintedBy": {
          "type": "string",
          "enum": ["gui", "host"]
        },
        "assistantMinted": {
          "type": "boolean",
          "const": false
        },
        "correlation": { "$ref": "#/$defs/correlation" },
        "requestedAt": { "$ref": "#/$defs/utcTimestamp" },
        "reason": { "$ref": "#/$defs/safeSummary" }
      }
    },
    "correlation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["origin", "confirmedBy", "confirmationId", "hostCorrelationId"],
      "properties": {
        "origin": {
          "type": "string",
          "enum": ["user", "host"]
        },
        "confirmedBy": {
          "type": "string",
          "enum": ["user", "host"]
        },
        "confirmationId": { "$ref": "#/$defs/safeId" },
        "hostCorrelationId": { "$ref": "#/$defs/safeId" },
        "confirmedAt": { "$ref": "#/$defs/utcTimestamp" },
        "label": { "$ref": "#/$defs/safeLabel" }
      }
    },
    "phase": {
      "type": "object",
      "additionalProperties": false,
      "required": ["state", "enteredAt", "sequence"],
      "properties": {
        "state": {
          "type": "string",
          "enum": [
            "idle",
            "opt_in_required",
            "workspace_ready",
            "reading_context",
            "planning",
            "waiting_for_user",
            "running_verification",
            "stopping",
            "stopped",
            "blocked",
            "failed",
            "completed"
          ]
        },
        "enteredAt": { "$ref": "#/$defs/utcTimestamp" },
        "sequence": {
          "type": "integer",
          "minimum": 0,
          "maximum": 1000
        },
        "label": { "$ref": "#/$defs/safeLabel" }
      }
    },
    "limits": {
      "type": "object",
      "additionalProperties": false,
      "required": ["maxSteps", "maxFileReads", "maxTouchedFiles", "maxPatchBytes", "maxVerificationRuns", "maxRuntimeSeconds"],
      "properties": {
        "maxSteps": { "type": "integer", "minimum": 1, "maximum": 12 },
        "maxFileReads": { "type": "integer", "minimum": 0, "maximum": 24 },
        "maxTouchedFiles": { "type": "integer", "minimum": 0, "maximum": 8 },
        "maxPatchBytes": { "type": "integer", "minimum": 0, "maximum": 24000 },
        "maxVerificationRuns": { "type": "integer", "minimum": 0, "maximum": 4 },
        "maxRuntimeSeconds": { "type": "integer", "minimum": 1, "maximum": 1800 },
        "limitLabel": { "$ref": "#/$defs/safeLabel" }
      }
    },
    "counters": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stepsCompleted", "fileReadsUsed", "filesTouched", "patchBytesUsed", "verificationRuns", "userTurns"],
      "properties": {
        "stepsCompleted": { "type": "integer", "minimum": 0, "maximum": 12 },
        "fileReadsUsed": { "type": "integer", "minimum": 0, "maximum": 24 },
        "filesTouched": { "type": "integer", "minimum": 0, "maximum": 8 },
        "patchBytesUsed": { "type": "integer", "minimum": 0, "maximum": 24000 },
        "verificationRuns": { "type": "integer", "minimum": 0, "maximum": 4 },
        "userTurns": { "type": "integer", "minimum": 0, "maximum": 20 }
      }
    },
    "policyFlags": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stateMetadataOnly",
        "autoStartAllowed",
        "autoApplyAllowed",
        "autoRunAllowed",
        "autoVerifyAllowed",
        "autoFixAllowed",
        "autoRollbackAllowed",
        "fileReadAllowed",
        "fileWriteAllowed",
        "shellAllowed",
        "gitAllowed",
        "networkAllowed",
        "providerAllowed",
        "toolAllowed",
        "rawPromptAllowed",
        "rawFileAllowed",
        "rawDiffAllowed",
        "rawCommandAllowed",
        "rawLogAllowed"
      ],
      "properties": {
        "stateMetadataOnly": { "type": "boolean", "const": true },
        "autoStartAllowed": { "type": "boolean", "const": false },
        "autoApplyAllowed": { "type": "boolean", "const": false },
        "autoRunAllowed": { "type": "boolean", "const": false },
        "autoVerifyAllowed": { "type": "boolean", "const": false },
        "autoFixAllowed": { "type": "boolean", "const": false },
        "autoRollbackAllowed": { "type": "boolean", "const": false },
        "fileReadAllowed": { "type": "boolean", "const": false },
        "fileWriteAllowed": { "type": "boolean", "const": false },
        "shellAllowed": { "type": "boolean", "const": false },
        "gitAllowed": { "type": "boolean", "const": false },
        "networkAllowed": { "type": "boolean", "const": false },
        "providerAllowed": { "type": "boolean", "const": false },
        "toolAllowed": { "type": "boolean", "const": false },
        "rawPromptAllowed": { "type": "boolean", "const": false },
        "rawFileAllowed": { "type": "boolean", "const": false },
        "rawDiffAllowed": { "type": "boolean", "const": false },
        "rawCommandAllowed": { "type": "boolean", "const": false },
        "rawLogAllowed": { "type": "boolean", "const": false }
      }
    },
    "stop": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reason", "stoppedAt", "recoverable", "message"],
      "properties": {
        "reason": {
          "type": "string",
          "enum": [
            "user_stop",
            "read_budget_exhausted",
            "step_limit",
            "file_limit",
            "patch_limit",
            "verification_failed",
            "policy_blocked",
            "timeout",
            "unsafe_metadata",
            "internal_error"
          ]
        },
        "stoppedAt": { "$ref": "#/$defs/utcTimestamp" },
        "recoverable": { "type": "boolean" },
        "message": { "$ref": "#/$defs/safeSummary" }
      }
    },
    "details": {
      "type": "object",
      "additionalProperties": false,
      "required": ["summary", "sanitized"],
      "properties": {
        "summary": { "$ref": "#/$defs/safeSummary" },
        "sanitized": { "type": "boolean", "const": true },
        "nextUserAction": {
          "type": "string",
          "enum": ["none", "review_opt_in", "review_plan", "review_stop", "review_failure", "review_completion"]
        },
        "evidenceLabel": { "$ref": "#/$defs/safeLabel" }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "phase": {
            "type": "object",
            "properties": {
              "state": { "enum": ["stopping", "stopped", "blocked", "failed"] }
            },
            "required": ["state"]
          }
        },
        "required": ["phase"]
      },
      "then": {
        "required": ["stop"],
        "properties": {
          "stop": {}
        }
      }
    },
    {
      "if": {
        "properties": {
          "phase": {
            "type": "object",
            "properties": {
              "state": { "enum": ["idle", "opt_in_required", "workspace_ready", "reading_context", "planning", "waiting_for_user", "running_verification", "completed"] }
            },
            "required": ["state"]
          }
        },
        "required": ["phase"]
      },
      "then": {
        "properties": {
          "stop": false
        }
      }
    },
    {
      "if": {
        "properties": {
          "workspace": {
            "type": "object",
            "properties": {
              "workspaceReady": { "const": false }
            },
            "required": ["workspaceReady"]
          }
        },
        "required": ["workspace"]
      },
      "then": {
        "properties": {
          "phase": {
            "type": "object",
            "properties": {
              "state": { "enum": ["idle", "opt_in_required", "blocked"] }
            }
          }
        }
      }
    }
  ]
}
