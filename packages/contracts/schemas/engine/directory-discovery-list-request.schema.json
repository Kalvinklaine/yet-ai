{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.yet-ai.example/contracts/engine/directory-discovery-list-request.schema.json",
  "title": "Engine Directory Discovery List Request",
  "description": "Lists children for the path-owned session using one opaque engine-issued directory handle.",
  "type": "object",
  "additionalProperties": false,
  "required": ["directoryHandle"],
  "properties": {
    "directoryHandle": { "type": "string", "pattern": "^dir_[a-f0-9]{32}$" }
  }
}
