{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.yet-ai.example/contracts/engine/planner-scheduler-tick.schema.json",
  "title": "Planner Scheduler Tick Audit Summary",
  "description": "Future/simulator-facing sanitized no-idle scheduler tick or audit summary. It records the next deterministic action and audited blockers without raw prompts, provider responses, tokens, auth codes, cookies, private paths, or workspace file contents.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "protocolVersion",
    "tickId",
    "poolId",
    "autonomousMode",
    "nextAction",
    "observedAt",
    "agentCounts",
    "cardCounts"
  ],
  "properties": {
    "protocolVersion": {
      "type": "string",
      "const": "2026-05-15"
    },
    "tickId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.-]{0,127}$"
    },
    "poolId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 96,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_-]{0,95}$"
    },
    "autonomousMode": {
      "type": "boolean"
    },
    "nextAction": {
      "type": "string",
      "enum": [
        "check_agents",
        "merge_completed",
        "verify_merge",
        "spawn_ready",
        "recover_failed",
        "plan_next_pool",
        "idle_blocked"
      ]
    },
    "idleReason": {
      "type": "string",
      "enum": [
        "waiting_for_user_decision",
        "waiting_for_external_dependency",
        "concurrency_limit_reached",
        "blocked_by_failed_verification",
        "blocked_by_policy",
        "all_work_closed",
        "autonomy_not_permitted"
      ]
    },
    "observedAt": {
      "type": "string",
      "format": "date-time"
    },
    "nextWatchdogCheckAt": {
      "type": "string",
      "format": "date-time"
    },
    "agentCounts": {
      "$ref": "#/$defs/agentCounts"
    },
    "cardCounts": {
      "$ref": "#/$defs/cardCounts"
    },
    "safeSummary": {
      "$ref": "#/$defs/safeSummary"
    },
    "overflowRecovery": {
      "$ref": "#/$defs/overflowRecovery"
    }
  },
  "$defs": {
    "count": {
      "type": "integer",
      "minimum": 0,
      "maximum": 10000
    },
    "agentCounts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "running",
        "done",
        "failed",
        "stuck",
        "unknown"
      ],
      "properties": {
        "running": {
          "$ref": "#/$defs/count"
        },
        "done": {
          "$ref": "#/$defs/count"
        },
        "failed": {
          "$ref": "#/$defs/count"
        },
        "stuck": {
          "$ref": "#/$defs/count"
        },
        "unknown": {
          "$ref": "#/$defs/count"
        }
      }
    },
    "cardCounts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "running",
        "done_unmerged",
        "merge_pending",
        "verification_pending",
        "verified",
        "blocked",
        "replan_required"
      ],
      "properties": {
        "running": {
          "$ref": "#/$defs/count"
        },
        "done_unmerged": {
          "$ref": "#/$defs/count"
        },
        "merge_pending": {
          "$ref": "#/$defs/count"
        },
        "verification_pending": {
          "$ref": "#/$defs/count"
        },
        "verified": {
          "$ref": "#/$defs/count"
        },
        "blocked": {
          "$ref": "#/$defs/count"
        },
        "replan_required": {
          "$ref": "#/$defs/count"
        }
      }
    },
    "safeText": {
      "type": "string",
      "pattern": "^(?![\\s\\S]*(?:[aA][pP][iI][-_ ]?[kK][eE][yY]|[aA][uU][tT][hH][oO][rR][iI][zZ][aA][tT][iI][oO][nN]|[bB][eE][aA][rR][eE][rR]|[tT][oO][kK][eE][nN]|[sS][eE][cC][rR][eE][tT]|[pP][aA][sS][sS][wW][oO][rR][dD]|[cC][oO][oO][kK][iI][eE]|[pP][kK][cC][eE]|[rR][eE][fF][rR][eE][sS][hH]|[aA][cC][cC][eE][sS][sS][-_ ]?[tT][oO][kK][eE][nN]|[aA][uU][tT][hH][-_ ]?[cC][oO][dD][eE]|[cC][hH][aA][iI][nN][-_ ]?[oO][fF][-_ ]?[tT][hH][oO][uU][gG][hH][tT]|[rR][aA][wW][-_ ]?(?:[pP][rR][oO][mM][pP][tT]|[dD][uU][mM][pP]|[oO][uU][tT][pP][uU][tT]|[fF][iI][lL][eE]|[wW][oO][rR][kK][sS][pP][aA][cC][eE])|[pP][rR][oO][vV][iI][dD][eE][rR][-_ ]?(?:[rR][eE][sS][pP][oO][nN][sS][eE]|[bB][oO][dD][yY])|[cC][rR][eE][dD][eE][nN][tT][iI][aA][lL]|[fF][iI][lL][eE][-_ ]?[cC][oO][nN][tT][eE][nN][tT]|[wW][oO][rR][kK][sS][pP][aA][cC][eE][-_ ]?(?:[fF][iI][lL][eE]|[cC][oO][nN][tT][eE][nN][tT])|/Users/|/home/|/private/|[A-Za-z]:\\\\|~/|\\.[cC][oO][dD][eE][xX]/[aA][uU][tT][hH]\\.json|(?:[aA][uU][tT][hH]|[cC][rR][eE][dD][eE][nN][tT][iI][aA][lL][sS]?)\\.json|BEGIN [A-Z ]*PRIVATE KEY))[\\s\\S]*$"
    },
    "safeSummary": {
      "allOf": [
        {
          "$ref": "#/$defs/safeText"
        },
        {
          "type": "string",
          "minLength": 1,
          "maxLength": 512
        }
      ]
    },
    "safeOverflowMessage": {
      "allOf": [
        {
          "$ref": "#/$defs/safeText"
        },
        {
          "type": "string",
          "minLength": 1,
          "maxLength": 320
        }
      ]
    },
    "overflowRecoveryKind": {
      "type": "string",
      "enum": [
        "context_length_exceeded",
        "tool_output_too_large",
        "task_board_output_too_large"
      ]
    },
    "overflowRecovery": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "message"
      ],
      "properties": {
        "kind": {
          "$ref": "#/$defs/overflowRecoveryKind"
        },
        "message": {
          "$ref": "#/$defs/safeOverflowMessage"
        },
        "retryable": {
          "type": "boolean"
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "nextAction": {
            "const": "idle_blocked"
          }
        },
        "required": [
          "nextAction"
        ]
      },
      "then": {
        "properties": {
          "idleReason": true,
          "nextWatchdogCheckAt": true
        },
        "required": [
          "idleReason",
          "nextWatchdogCheckAt"
        ]
      },
      "else": {
        "not": {
          "required": [
            "idleReason"
          ]
        }
      }
    },
    {
      "if": {
        "properties": {
          "overflowRecovery": true
        },
        "required": [
          "overflowRecovery"
        ]
      },
      "then": {
        "properties": {
          "nextAction": {
            "enum": [
              "recover_failed",
              "idle_blocked"
            ]
          }
        },
        "required": [
          "nextAction"
        ]
      }
    }
  ]
}
