{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.yet-ai.example/contracts/engine/provider-auth-start-response.schema.json",
  "title": "Engine Provider Auth Start Response",
  "type": "object",
  "additionalProperties": false,
  "required": ["provider", "configured", "status", "authSource", "supportsLogin", "supportsApiKey", "cloudRequired", "success"],
  "allOf": [
    {
      "if": {
        "properties": { "status": { "const": "api_key_configured" } },
        "required": ["status"]
      },
      "then": {
        "properties": {
          "configured": { "const": true },
          "authSource": { "const": "api_key" }
        }
      }
    },
    {
      "if": {
        "properties": { "status": { "enum": ["pending", "connected", "expired"] } },
        "required": ["status"]
      },
      "then": {
        "properties": {
          "authSource": { "enum": ["oauth", "device", "browser"] }
        }
      }
    }
  ],
  "properties": {
    "provider": {
      "$ref": "#/$defs/providerId"
    },
    "configured": {
      "type": "boolean"
    },
    "status": {
      "$ref": "#/$defs/authStatus"
    },
    "authSource": {
      "$ref": "#/$defs/authSource"
    },
    "supportsLogin": {
      "type": "boolean"
    },
    "supportsApiKey": {
      "type": "boolean"
    },
    "authorizationUrl": {
      "type": "string",
      "format": "uri",
      "pattern": "^https://"
    },
    "verificationUrl": {
      "type": "string",
      "format": "uri",
      "pattern": "^https://"
    },
    "sessionId": {
      "type": "string",
      "minLength": 1
    },
    "accountLabel": {
      "type": "string",
      "minLength": 1
    },
    "expiresAt": {
      "type": "string",
      "format": "date-time"
    },
    "scopes": {
      "$ref": "#/$defs/scopes"
    },
    "redacted": {
      "type": "string",
      "minLength": 1
    },
    "lastError": {
      "type": "string",
      "minLength": 1
    },
    "cloudRequired": {
      "type": "boolean",
      "const": false
    },
    "message": {
      "type": "string",
      "minLength": 1
    },
    "success": {
      "type": "boolean"
    },
    "pollIntervalSeconds": {
      "type": "integer",
      "minimum": 1,
      "maximum": 3600
    }
  },
  "$defs": {
    "providerId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_-]{0,63}$"
    },
    "authStatus": {
      "type": "string",
      "enum": [
        "not_configured",
        "api_key_configured",
        "login_available",
        "login_unavailable",
        "pending",
        "connected",
        "expired",
        "revoked",
        "error"
      ]
    },
    "authSource": {
      "type": "string",
      "enum": ["none", "api_key", "oauth", "device", "browser"]
    },
    "scopes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    }
  }
}
