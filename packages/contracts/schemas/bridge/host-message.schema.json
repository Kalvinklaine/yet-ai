{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.yet-ai.example/contracts/bridge/host-message.schema.json",
  "title": "IDE Host to GUI Message",
  "description": "Strict host bootstrap, active editor context, current sanitized controlled IDE action progress/results, and confirmed edit proposal results only. Controlled IDE action messages are local-only read/context/navigation status messages and must not expose secrets, private absolute paths, raw contents, shell output, git output, task output, provider responses, or arbitrary payloads.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "type"
  ],
  "properties": {
    "version": {
      "type": "string",
      "const": "2026-05-15"
    },
    "type": {
      "type": "string",
      "enum": [
        "host.ready",
        "host.openedFromCommand",
        "host.contextSnapshot",
        "host.ideActionProgress",
        "host.ideActionResult",
        "host.applyWorkspaceEditResult",
        "host.runtimeStatus"
      ]
    },
    "requestId": {
      "$ref": "#/$defs/requestId"
    },
    "payload": {
      "type": "object"
    }
  },
  "$defs": {
    "requestId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^(?!.*(?:[Aa][Uu][Tt][Hh][Oo][Rr][Ii][Zz][Aa][Tt][Ii][Oo][Nn]|[Bb][Ee][Aa][Rr][Ee][Rr]|[Aa][Pp][Ii][-_]?[Kk][Ee][Yy]|[Tt][Oo][Kk][Ee][Nn]|[Ss][Ee][Cc][Rr][Ee][Tt]|[Aa][Cc][Cc][Ee][Ss][Ss][-_]?[Tt][Oo][Kk][Ee][Nn]|[Pp][Rr][Oo][Vv][Ii][Dd][Ee][Rr][-_]?[Kk][Ee][Yy]|[Oo][Pp][Ee][Nn][Aa][Ii][-_]?[Aa][Pp][Ii][-_]?[Kk][Ee][Yy]|[Ss][Kk]-(?:[Pp][Rr][Oo][Jj]-)?[A-Za-z0-9_-]{8,}))[A-Za-z0-9][A-Za-z0-9_.-]{0,127}$"
    },
    "safeRelativePath": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512,
      "pattern": "^(?!/)(?!~)(?!.*%)(?!.*\\\\)(?!.*:)(?!.*[?#])(?!.*(?:^|/)\\.\\.?(?:/|$))(?!.*//)(?!.*\\/$)(?!.*(?:^|/)(?:[Aa][Uu][Tt][Hh]|[Aa][Uu][Tt][Hh][Oo][Rr][Ii][Zz][Aa][Tt][Ii][Oo][Nn]|[Bb][Ee][Aa][Rr][Ee][Rr]|[Cc][Oo][Oo][Kk][Ii][Ee]|[Cc][Rr][Ee][Dd][Ee][Nn][Tt][Ii][Aa][Ll][Ss]?|[Pp][Aa][Ss][Ss][Ww][Oo][Rr][Dd]|[Ss][Ee][Cc][Rr][Ee][Tt]|[Tt][Oo][Kk][Ee][Nn]|[Aa][Cc][Cc][Ee][Ss][Ss][_-]?[Tt][Oo][Kk][Ee][Nn]|[Aa][Pp][Ii][_-]?[Kk][Ee][Yy])(?:[._-]|/|$))(?!.*(?:^|[._-])(?:[Aa][Uu][Tt][Hh]|[Cc][Rr][Ee][Dd][Ee][Nn][Tt][Ii][Aa][Ll][Ss]?|[Pp][Aa][Ss][Ss][Ww][Oo][Rr][Dd]|[Ss][Ee][Cc][Rr][Ee][Tt]|[Tt][Oo][Kk][Ee][Nn]|[Aa][Cc][Cc][Ee][Ss][Ss][_-]?[Tt][Oo][Kk][Ee][Nn]|[Aa][Pp][Ii][_-]?[Kk][Ee][Yy])(?:[._-]|$))(?!.*(?:^|/)[Ss][Kk]-(?:[Pp][Rr][Oo][Jj]-)?[A-Za-z0-9_-]{8,})[^\\u0000-\\u001f\\u007f-\\u009f]+$"
    },
    "safeDisplayPath": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "pattern": "^(?!/)(?!~)(?!.*%)(?!.*\\\\)(?!.*:)(?!.*[?#])(?!.*(?:^|/)\\.\\.?(?:/|$))(?!.*(?:^|/)(?:[Aa][Uu][Tt][Hh]|[Aa][Uu][Tt][Hh][Oo][Rr][Ii][Zz][Aa][Tt][Ii][Oo][Nn]|[Bb][Ee][Aa][Rr][Ee][Rr]|[Cc][Oo][Oo][Kk][Ii][Ee]|[Cc][Rr][Ee][Dd][Ee][Nn][Tt][Ii][Aa][Ll][Ss]?|[Pp][Aa][Ss][Ss][Ww][Oo][Rr][Dd]|[Ss][Ee][Cc][Rr][Ee][Tt]|[Tt][Oo][Kk][Ee][Nn]|[Aa][Cc][Cc][Ee][Ss][Ss][_-]?[Tt][Oo][Kk][Ee][Nn]|[Aa][Pp][Ii][_-]?[Kk][Ee][Yy])(?:[._-]|/|$))(?!.*(?:^|[._-])(?:[Aa][Uu][Tt][Hh]|[Cc][Rr][Ee][Dd][Ee][Nn][Tt][Ii][Aa][Ll][Ss]?|[Pp][Aa][Ss][Ss][Ww][Oo][Rr][Dd]|[Ss][Ee][Cc][Rr][Ee][Tt]|[Tt][Oo][Kk][Ee][Nn]|[Aa][Cc][Cc][Ee][Ss][Ss][_-]?[Tt][Oo][Kk][Ee][Nn]|[Aa][Pp][Ii][_-]?[Kk][Ee][Yy])(?:[._-]|$))(?!.*(?:^|/)[Ss][Kk]-(?:[Pp][Rr][Oo][Jj]-)?[A-Za-z0-9_-]{8,})(?!.*//)(?!.*\\/$)[^\\u0000-\\u001f\\u007f-\\u009f]+$"
    },
    "safeMessage": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1000,
      "pattern": "^(?!.*(?:[\u0000-\u001f\u007f-\u009f]|[Aa][Uu][Tt][Hh][Oo][Rr][Ii][Zz][Aa][Tt][Ii][Oo][Nn]|[Bb][Ee][Aa][Rr][Ee][Rr]|[Cc][Oo][Oo][Kk][Ii][Ee]|[Aa][Pp][Ii][_-]?[Kk][Ee][Yy]|[Tt][Oo][Kk][Ee][Nn]|[Ss][Ee][Cc][Rr][Ee][Tt]|[Pp][Aa][Ss][Ss][Ww][Oo][Rr][Dd]|[Pp][Rr][Ii][Vv][Aa][Tt][Ee][_-]?[Pp][Aa][Tt][Hh]|[Pp][Rr][Oo][Vv][Ii][Dd][Ee][Rr][_-]?[Rr][Ee][Ss][Pp][Oo][Nn][Ss][Ee]|[Rr][Aa][Ww][_-]?[Pp][Rr][Oo][Mm][Pp][Tt]|[Ff][Ii][Ll][Ee][_-]?[Cc][Oo][Nn][Tt][Ee][Nn][Tt]|/[Uu][Ss][Ee][Rr][Ss](?=/|$|[^A-Za-z0-9_])|/[Hh][Oo][Mm][Ee](?=/|$|[^A-Za-z0-9_])|/[Tt][Mm][Pp](?=/|$|[^A-Za-z0-9_])|/[Vv][Aa][Rr](?=/|$|[^A-Za-z0-9_])|/[Ee][Tt][Cc](?=/|$|[^A-Za-z0-9_])|/[Oo][Pp][Tt](?=/|$|[^A-Za-z0-9_])|/[Mm][Nn][Tt](?=/|$|[^A-Za-z0-9_])|/[Vv][Oo][Ll][Uu][Mm][Ee][Ss](?=/|$|[^A-Za-z0-9_])|/[Pp][Rr][Ii][Vv][Aa][Tt][Ee](?=/|$|[^A-Za-z0-9_])|[A-Za-z]:(?:/|\\\\)|~(?:/|\\\\)|(?:^|[^A-Za-z0-9_-])[Ss][Kk]-(?:[Pp][Rr][Oo][Jj]-)?[A-Za-z0-9_-]{8,})).*$"
    },
    "activeEditorContext": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "source"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "const": "active_editor"
        },
        "source": {
          "type": "string",
          "enum": [
            "vscode",
            "jetbrains",
            "browser"
          ]
        },
        "file": {
          "type": "object",
          "additionalProperties": false,
          "minProperties": 1,
          "properties": {
            "displayPath": {
              "$ref": "#/$defs/safeDisplayPath"
            },
            "workspaceRelativePath": {
              "$ref": "#/$defs/safeRelativePath"
            },
            "languageId": {
              "type": "string",
              "minLength": 1,
              "maxLength": 64,
              "pattern": "^[A-Za-z0-9_.+-]+$"
            }
          }
        },
        "selection": {
          "description": "Bounded active user-selected prompt context only. Selection text is not valid IDE action metadata and does not grant file read, edit, shell, task, git, tool, provider response, or raw prompt authority.",
          "type": "object",
          "additionalProperties": false,
          "minProperties": 1,
          "allOf": [
            {
              "if": {
                "type": "object",
                "properties": {
                  "startLine": true,
                  "startCharacter": true,
                  "endLine": true,
                  "endCharacter": true
                },
                "anyOf": [
                  {
                    "properties": {
                      "startLine": true
                    },
                    "required": [
                      "startLine"
                    ]
                  },
                  {
                    "properties": {
                      "startCharacter": true
                    },
                    "required": [
                      "startCharacter"
                    ]
                  },
                  {
                    "properties": {
                      "endLine": true
                    },
                    "required": [
                      "endLine"
                    ]
                  },
                  {
                    "properties": {
                      "endCharacter": true
                    },
                    "required": [
                      "endCharacter"
                    ]
                  }
                ]
              },
              "then": {
                "required": [
                  "startLine",
                  "startCharacter",
                  "endLine",
                  "endCharacter"
                ]
              }
            },
            {
              "if": {
                "properties": {
                  "startLine": true,
                  "startCharacter": true,
                  "endLine": true,
                  "endCharacter": true
                },
                "required": [
                  "startLine",
                  "startCharacter",
                  "endLine",
                  "endCharacter"
                ]
              },
              "then": {
                "properties": {
                  "endLine": {
                    "type": "integer",
                    "minimum": {
                      "$data": "1/startLine"
                    }
                  }
                }
              }
            },
            {
              "if": {
                "properties": {
                  "endLine": {
                    "type": "integer",
                    "const": {
                      "$data": "1/startLine"
                    }
                  }
                },
                "required": [
                  "startLine",
                  "startCharacter",
                  "endLine",
                  "endCharacter"
                ]
              },
              "then": {
                "properties": {
                  "endCharacter": {
                    "type": "integer",
                    "minimum": {
                      "$data": "1/startCharacter"
                    }
                  }
                }
              }
            }
          ],
          "properties": {
            "startLine": {
              "type": "integer",
              "minimum": 0,
              "maximum": 1000000
            },
            "startCharacter": {
              "type": "integer",
              "minimum": 0,
              "maximum": 1000000
            },
            "endLine": {
              "type": "integer",
              "minimum": 0,
              "maximum": 1000000
            },
            "endCharacter": {
              "type": "integer",
              "minimum": 0,
              "maximum": 1000000
            },
            "text": {
              "type": "string",
              "maxLength": 8000
            }
          }
        }
      }
    },
    "applyWorkspaceEditResultPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "message",
        "cloudRequired"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "applied",
            "denied",
            "rejected",
            "failed"
          ]
        },
        "message": {
          "$ref": "#/$defs/safeMessage"
        },
        "cloudRequired": {
          "type": "boolean",
          "const": false
        },
        "appliedEditCount": {
          "type": "integer",
          "minimum": 0,
          "maximum": 64
        },
        "affectedFiles": {
          "type": "array",
          "maxItems": 4,
          "items": {
            "$ref": "#/$defs/safeRelativePath"
          }
        }
      }
    },
    "position": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "line",
        "character"
      ],
      "properties": {
        "line": {
          "type": "integer",
          "minimum": 0,
          "maximum": 1000000
        },
        "character": {
          "type": "integer",
          "minimum": 0,
          "maximum": 1000000
        }
      }
    },
    "range": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "start",
        "end"
      ],
      "properties": {
        "start": {
          "$ref": "#/$defs/position"
        },
        "end": {
          "$ref": "#/$defs/position"
        }
      },
      "allOf": [
        {
          "properties": {
            "end": {
              "type": "object",
              "properties": {
                "line": {
                  "type": "integer",
                  "minimum": {
                    "$data": "2/start/line"
                  }
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "start": {
                "type": "object",
                "properties": {
                  "line": true
                },
                "required": [
                  "line"
                ]
              },
              "end": {
                "type": "object",
                "properties": {
                  "line": {
                    "type": "integer",
                    "const": {
                      "$data": "2/start/line"
                    }
                  }
                },
                "required": [
                  "line"
                ]
              }
            },
            "required": [
              "start",
              "end"
            ]
          },
          "then": {
            "properties": {
              "end": {
                "type": "object",
                "properties": {
                  "character": {
                    "type": "integer",
                    "minimum": {
                      "$data": "2/start/character"
                    }
                  }
                }
              }
            }
          }
        }
      ]
    },
    "ideActionType": {
      "type": "string",
      "enum": [
        "getContextSnapshot",
        "openWorkspaceFile",
        "revealWorkspaceRange",
        "getActiveFileExcerpt",
        "runVerificationCommand",
        "searchWorkspaceSnippets"
      ]
    },
    "ideActionResultPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "message",
        "cloudRequired"
      ],
      "allOf": [
        {
          "if": {
            "properties": {
              "action": {
                "const": "getContextSnapshot"
              }
            },
            "required": [
              "action"
            ]
          },
          "then": {
            "properties": {
              "workspaceRelativePath": false,
              "range": false
            }
          }
        },
        {
          "if": {
            "properties": {
              "action": {
                "const": "getActiveFileExcerpt"
              }
            },
            "required": [
              "action"
            ]
          },
          "then": {
            "properties": {
              "workspaceRelativePath": false,
              "range": false,
              "context": false
            }
          }
        },
        {
          "if": {
            "properties": {
              "action": {
                "const": "searchWorkspaceSnippets"
              }
            },
            "required": [
              "action"
            ]
          },
          "then": {
            "properties": {
              "workspaceRelativePath": false,
              "range": false,
              "context": false,
              "contextAttachment": false,
              "commandId": false,
              "exitCode": false,
              "durationMs": false,
              "outputTail": false
            }
          }
        },
        {
          "if": {
            "properties": {
              "action": {
                "enum": [
                  "openWorkspaceFile",
                  "revealWorkspaceRange"
                ]
              }
            },
            "required": [
              "action"
            ]
          },
          "then": {
            "properties": {
              "context": false
            }
          }
        },
        {
          "if": {
            "properties": {
              "action": {
                "const": "runVerificationCommand"
              }
            },
            "required": [
              "action"
            ]
          },
          "then": {
            "properties": {
              "workspaceRelativePath": false,
              "range": false,
              "context": false,
              "contextAttachment": false
            }
          }
        },
        {
          "if": {
            "properties": {
              "status": {
                "const": "succeeded"
              }
            },
            "required": [
              "status"
            ]
          },
          "then": {
            "properties": {
              "action": {
                "$ref": "#/$defs/ideActionType"
              }
            },
            "required": [
              "action"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "status": {
                "const": "succeeded"
              },
              "action": {
                "const": "getContextSnapshot"
              }
            },
            "required": [
              "status",
              "action"
            ]
          },
          "then": {
            "properties": {
              "workspaceRelativePath": false,
              "range": false,
              "context": true
            },
            "required": [
              "context"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "status": {
                "const": "succeeded"
              },
              "action": {
                "const": "getActiveFileExcerpt"
              }
            },
            "required": [
              "status",
              "action"
            ]
          },
          "then": {
            "properties": {
              "workspaceRelativePath": false,
              "range": false,
              "context": false,
              "contextAttachment": {
                "$ref": "#/$defs/activeFileExcerptAttachment"
              }
            },
            "required": [
              "contextAttachment"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "status": {
                "const": "succeeded"
              },
              "action": {
                "const": "searchWorkspaceSnippets"
              }
            },
            "required": [
              "status",
              "action"
            ]
          },
          "then": {
            "properties": {
              "workspaceRelativePath": false,
              "range": false,
              "context": false,
              "contextAttachment": false,
              "queryLabel": {
                "$ref": "#/$defs/workspaceSnippetQueryLabel"
              },
              "resultCount": {
                "type": "integer",
                "minimum": 0,
                "maximum": 20
              },
              "snippets": {
                "type": "array",
                "minItems": 0,
                "maxItems": 20,
                "items": {
                  "$ref": "#/$defs/workspaceSnippet"
                }
              },
              "truncated": {
                "type": "boolean"
              }
            },
            "required": [
              "queryLabel",
              "resultCount",
              "snippets",
              "truncated"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "status": {
                "const": "succeeded"
              },
              "action": {
                "const": "openWorkspaceFile"
              }
            },
            "required": [
              "status",
              "action"
            ]
          },
          "then": {
            "properties": {
              "workspaceRelativePath": {
                "$ref": "#/$defs/safeRelativePath"
              },
              "range": false,
              "context": false
            },
            "required": [
              "workspaceRelativePath"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "status": {
                "const": "succeeded"
              },
              "action": {
                "const": "revealWorkspaceRange"
              }
            },
            "required": [
              "status",
              "action"
            ]
          },
          "then": {
            "properties": {
              "workspaceRelativePath": {
                "$ref": "#/$defs/safeRelativePath"
              },
              "range": {
                "$ref": "#/$defs/range"
              },
              "context": false
            },
            "required": [
              "workspaceRelativePath",
              "range"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "status": {
                "enum": [
                  "rejected",
                  "unavailable",
                  "failed"
                ]
              }
            },
            "required": [
              "status"
            ]
          },
          "then": {
            "properties": {
              "contextAttachment": false,
              "queryLabel": false,
              "resultCount": false,
              "snippets": false
            }
          }
        },
        {
          "if": {
            "properties": {
              "action": {
                "const": "runVerificationCommand"
              }
            },
            "required": [
              "action"
            ]
          },
          "then": {
            "required": [
              "commandId",
              "exitCode",
              "durationMs",
              "outputTail",
              "truncated"
            ],
            "properties": {
              "commandId": {
                "$ref": "#/$defs/verificationCommandId"
              },
              "exitCode": {
                "type": "integer",
                "minimum": 0,
                "maximum": 255
              },
              "durationMs": {
                "type": "integer",
                "minimum": 0,
                "maximum": 3600000
              },
              "outputTail": {
                "$ref": "#/$defs/verificationOutputTail"
              },
              "truncated": {
                "type": "boolean"
              }
            }
          }
        }
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "succeeded",
            "rejected",
            "unavailable",
            "failed"
          ]
        },
        "message": {
          "$ref": "#/$defs/safeMessage"
        },
        "cloudRequired": {
          "type": "boolean",
          "const": false
        },
        "action": {
          "$ref": "#/$defs/ideActionType"
        },
        "workspaceRelativePath": {
          "$ref": "#/$defs/safeRelativePath"
        },
        "range": {
          "$ref": "#/$defs/range"
        },
        "context": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "source",
            "hasActiveEditor",
            "workspaceFolderCount"
          ],
          "properties": {
            "source": {
              "type": "string",
              "enum": [
                "vscode",
                "jetbrains"
              ]
            },
            "hasActiveEditor": {
              "type": "boolean"
            },
            "workspaceFolderCount": {
              "type": "integer",
              "minimum": 0,
              "maximum": 100
            }
          }
        },
        "contextAttachment": {
          "$ref": "#/$defs/activeFileExcerptAttachment"
        },
        "commandId": {
          "$ref": "#/$defs/verificationCommandId"
        },
        "exitCode": {
          "type": "integer",
          "minimum": 0,
          "maximum": 255
        },
        "durationMs": {
          "type": "integer",
          "minimum": 0,
          "maximum": 3600000
        },
        "outputTail": {
          "$ref": "#/$defs/verificationOutputTail"
        },
        "truncated": {
          "type": "boolean"
        },
        "queryLabel": {
          "$ref": "#/$defs/workspaceSnippetQueryLabel"
        },
        "resultCount": {
          "type": "integer",
          "minimum": 0,
          "maximum": 20
        },
        "snippets": {
          "type": "array",
          "minItems": 0,
          "maxItems": 20,
          "items": {
            "$ref": "#/$defs/workspaceSnippet"
          }
        }
      }
    },
    "ideActionProgressPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "phase",
        "status",
