{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.yet-ai.example/contracts/bridge/host-message.schema.json",
  "title": "IDE Host to GUI Message",
  "description": "Strict host bootstrap, active editor context, current sanitized controlled IDE action progress/results, and confirmed edit proposal results only. Controlled IDE action messages are local-only read/context/navigation status messages and must not expose secrets, private absolute paths, raw contents, shell output, git output, task output, provider responses, or arbitrary payloads.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "type"
  ],
  "properties": {
    "version": {
      "type": "string",
      "const": "2026-05-15"
    },
    "type": {
      "type": "string",
      "enum": [
        "host.ready",
        "host.openedFromCommand",
        "host.contextSnapshot",
        "host.ideActionProgress",
        "host.ideActionResult",
        "host.applyWorkspaceEditResult"
      ]
    },
    "requestId": {
      "$ref": "#/$defs/requestId"
    },
    "payload": {
      "type": "object"
    }
  },
  "$defs": {
    "requestId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^(?!.*(?:[Aa][Uu][Tt][Hh][Oo][Rr][Ii][Zz][Aa][Tt][Ii][Oo][Nn]|[Bb][Ee][Aa][Rr][Ee][Rr]|[Aa][Pp][Ii][-_]?[Kk][Ee][Yy]|[Tt][Oo][Kk][Ee][Nn]|[Ss][Ee][Cc][Rr][Ee][Tt]|[Aa][Cc][Cc][Ee][Ss][Ss][-_]?[Tt][Oo][Kk][Ee][Nn]|[Ss][Kk]-(?:[Pp][Rr][Oo][Jj]-)?[A-Za-z0-9_-]{8,}))[A-Za-z0-9][A-Za-z0-9_.-]{0,127}$"
    },
    "safeRelativePath": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512,
      "pattern": "^(?!/)(?!~)(?!.*%)(?!.*\\\\)(?!.*:)(?!.*[?#])(?!.*(?:^|/)\\.\\.?(?:/|$))(?!.*//)(?!.*\\/$)(?!.*(?:^|/)(?:[Aa][Uu][Tt][Hh]|[Aa][Uu][Tt][Hh][Oo][Rr][Ii][Zz][Aa][Tt][Ii][Oo][Nn]|[Bb][Ee][Aa][Rr][Ee][Rr]|[Cc][Oo][Oo][Kk][Ii][Ee]|[Cc][Rr][Ee][Dd][Ee][Nn][Tt][Ii][Aa][Ll][Ss]?|[Pp][Aa][Ss][Ss][Ww][Oo][Rr][Dd]|[Ss][Ee][Cc][Rr][Ee][Tt]|[Tt][Oo][Kk][Ee][Nn]|[Aa][Cc][Cc][Ee][Ss][Ss][_-]?[Tt][Oo][Kk][Ee][Nn]|[Aa][Pp][Ii][_-]?[Kk][Ee][Yy])(?:[._-]|/|$))(?!.*(?:^|[._-])(?:[Aa][Uu][Tt][Hh]|[Cc][Rr][Ee][Dd][Ee][Nn][Tt][Ii][Aa][Ll][Ss]?|[Pp][Aa][Ss][Ss][Ww][Oo][Rr][Dd]|[Ss][Ee][Cc][Rr][Ee][Tt]|[Tt][Oo][Kk][Ee][Nn]|[Aa][Cc][Cc][Ee][Ss][Ss][_-]?[Tt][Oo][Kk][Ee][Nn]|[Aa][Pp][Ii][_-]?[Kk][Ee][Yy])(?:[._-]|$))(?!.*(?:^|/)[Ss][Kk]-(?:[Pp][Rr][Oo][Jj]-)?[A-Za-z0-9_-]{8,})[^\\u0000-\\u001f\\u007f-\\u009f]+$"
    },
    "safeDisplayPath": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "pattern": "^(?!/)(?!~)(?!.*%)(?!.*\\\\)(?!.*:)(?!.*[?#])(?!.*(?:^|/)\\.\\.?(?:/|$))(?!.*(?:^|/)(?:[Aa][Uu][Tt][Hh]|[Aa][Uu][Tt][Hh][Oo][Rr][Ii][Zz][Aa][Tt][Ii][Oo][Nn]|[Bb][Ee][Aa][Rr][Ee][Rr]|[Cc][Oo][Oo][Kk][Ii][Ee]|[Cc][Rr][Ee][Dd][Ee][Nn][Tt][Ii][Aa][Ll][Ss]?|[Pp][Aa][Ss][Ss][Ww][Oo][Rr][Dd]|[Ss][Ee][Cc][Rr][Ee][Tt]|[Tt][Oo][Kk][Ee][Nn]|[Aa][Cc][Cc][Ee][Ss][Ss][_-]?[Tt][Oo][Kk][Ee][Nn]|[Aa][Pp][Ii][_-]?[Kk][Ee][Yy])(?:[._-]|/|$))(?!.*(?:^|[._-])(?:[Aa][Uu][Tt][Hh]|[Cc][Rr][Ee][Dd][Ee][Nn][Tt][Ii][Aa][Ll][Ss]?|[Pp][Aa][Ss][Ss][Ww][Oo][Rr][Dd]|[Ss][Ee][Cc][Rr][Ee][Tt]|[Tt][Oo][Kk][Ee][Nn]|[Aa][Cc][Cc][Ee][Ss][Ss][_-]?[Tt][Oo][Kk][Ee][Nn]|[Aa][Pp][Ii][_-]?[Kk][Ee][Yy])(?:[._-]|$))(?!.*(?:^|/)[Ss][Kk]-(?:[Pp][Rr][Oo][Jj]-)?[A-Za-z0-9_-]{8,})(?!.*//)(?!.*\\/$)[^\\u0000-\\u001f\\u007f-\\u009f]+$"
    },
    "safeMessage": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1000,
      "pattern": "^(?!.*(?:[\u0000-\u001f\u007f-\u009f]|[Aa][Uu][Tt][Hh][Oo][Rr][Ii][Zz][Aa][Tt][Ii][Oo][Nn]|[Bb][Ee][Aa][Rr][Ee][Rr]|[Cc][Oo][Oo][Kk][Ii][Ee]|[Aa][Pp][Ii][_-]?[Kk][Ee][Yy]|[Tt][Oo][Kk][Ee][Nn]|[Ss][Ee][Cc][Rr][Ee][Tt]|[Pp][Aa][Ss][Ss][Ww][Oo][Rr][Dd]|[Pp][Rr][Ii][Vv][Aa][Tt][Ee][_-]?[Pp][Aa][Tt][Hh]|[Pp][Rr][Oo][Vv][Ii][Dd][Ee][Rr][_-]?[Rr][Ee][Ss][Pp][Oo][Nn][Ss][Ee]|[Rr][Aa][Ww][_-]?[Pp][Rr][Oo][Mm][Pp][Tt]|[Ff][Ii][Ll][Ee][_-]?[Cc][Oo][Nn][Tt][Ee][Nn][Tt]|/[Uu][Ss][Ee][Rr][Ss](?=/|$|[^A-Za-z0-9_])|/[Hh][Oo][Mm][Ee](?=/|$|[^A-Za-z0-9_])|/[Tt][Mm][Pp](?=/|$|[^A-Za-z0-9_])|/[Vv][Aa][Rr](?=/|$|[^A-Za-z0-9_])|/[Ee][Tt][Cc](?=/|$|[^A-Za-z0-9_])|/[Oo][Pp][Tt](?=/|$|[^A-Za-z0-9_])|/[Mm][Nn][Tt](?=/|$|[^A-Za-z0-9_])|/[Vv][Oo][Ll][Uu][Mm][Ee][Ss](?=/|$|[^A-Za-z0-9_])|/[Pp][Rr][Ii][Vv][Aa][Tt][Ee](?=/|$|[^A-Za-z0-9_])|[A-Za-z]:(?:/|\\\\)|~(?:/|\\\\)|(?:^|[^A-Za-z0-9_-])[Ss][Kk]-(?:[Pp][Rr][Oo][Jj]-)?[A-Za-z0-9_-]{8,})).*$"
    },
    "activeEditorContext": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "source"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "const": "active_editor"
        },
        "source": {
          "type": "string",
          "enum": [
            "vscode",
            "jetbrains",
            "browser"
          ]
        },
        "file": {
          "type": "object",
          "additionalProperties": false,
          "minProperties": 1,
          "properties": {
            "displayPath": {
              "$ref": "#/$defs/safeDisplayPath"
            },
            "workspaceRelativePath": {
              "$ref": "#/$defs/safeRelativePath"
            },
            "languageId": {
              "type": "string",
              "minLength": 1,
              "maxLength": 64,
              "pattern": "^[A-Za-z0-9_.+-]+$"
            }
          }
        },
        "selection": {
          "type": "object",
          "additionalProperties": false,
          "minProperties": 1,
          "allOf": [
            {
              "if": {
                "type": "object",
                "properties": {
                  "startLine": true,
                  "startCharacter": true,
                  "endLine": true,
                  "endCharacter": true
                },
                "anyOf": [
                  { "properties": { "startLine": true }, "required": ["startLine"] },
                  { "properties": { "startCharacter": true }, "required": ["startCharacter"] },
                  { "properties": { "endLine": true }, "required": ["endLine"] },
                  { "properties": { "endCharacter": true }, "required": ["endCharacter"] }
                ]
              },
              "then": {
                "required": [
                  "startLine",
                  "startCharacter",
                  "endLine",
                  "endCharacter"
                ]
              }
            },
            {
              "if": {
                "properties": {
                  "startLine": true,
                  "startCharacter": true,
                  "endLine": true,
                  "endCharacter": true
                },
                "required": [
                  "startLine",
                  "startCharacter",
                  "endLine",
                  "endCharacter"
                ]
              },
              "then": {
                "properties": {
                  "endLine": {
                    "type": "integer",
                    "minimum": {
                      "$data": "1/startLine"
                    }
                  }
                }
              }
            },
            {
              "if": {
                "properties": {
                  "endLine": {
                    "type": "integer",
                    "const": {
                      "$data": "1/startLine"
                    }
                  }
                },
                "required": [
                  "startLine",
                  "startCharacter",
                  "endLine",
                  "endCharacter"
                ]
              },
              "then": {
                "properties": {
                  "endCharacter": {
                    "type": "integer",
                    "minimum": {
                      "$data": "1/startCharacter"
                    }
                  }
                }
              }
            }
          ],
          "properties": {
            "startLine": {
              "type": "integer",
              "minimum": 0,
              "maximum": 1000000
            },
            "startCharacter": {
              "type": "integer",
              "minimum": 0,
              "maximum": 1000000
            },
            "endLine": {
              "type": "integer",
              "minimum": 0,
              "maximum": 1000000
            },
            "endCharacter": {
              "type": "integer",
              "minimum": 0,
              "maximum": 1000000
            },
            "text": {
              "type": "string",
              "maxLength": 8000
            }
          }
        }
      }
    },
    "applyWorkspaceEditResultPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "message",
        "cloudRequired"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "applied",
            "denied",
            "rejected",
            "failed"
          ]
        },
        "message": {
          "$ref": "#/$defs/safeMessage"
        },
        "cloudRequired": {
          "type": "boolean",
          "const": false
        },
        "appliedEditCount": {
          "type": "integer",
          "minimum": 0,
          "maximum": 64
        },
        "affectedFiles": {
          "type": "array",
          "maxItems": 4,
          "items": {
            "$ref": "#/$defs/safeRelativePath"
          }
        }
      }
    },
    "position": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "line",
        "character"
      ],
      "properties": {
        "line": {
          "type": "integer",
          "minimum": 0,
          "maximum": 1000000
        },
        "character": {
          "type": "integer",
          "minimum": 0,
          "maximum": 1000000
        }
      }
    },
    "range": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "start",
        "end"
      ],
      "properties": {
        "start": {
          "$ref": "#/$defs/position"
        },
        "end": {
          "$ref": "#/$defs/position"
        }
      },
      "allOf": [
        {
          "properties": {
            "end": {
              "type": "object",
              "properties": {
                "line": {
                  "type": "integer",
                  "minimum": {
                    "$data": "2/start/line"
                  }
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "start": {
                "type": "object",
                "properties": {
                  "line": true
                },
                "required": [
                  "line"
                ]
              },
              "end": {
                "type": "object",
                "properties": {
                  "line": {
                    "type": "integer",
                    "const": {
                      "$data": "2/start/line"
                    }
                  }
                },
                "required": [
                  "line"
                ]
              }
            },
            "required": [
              "start",
              "end"
            ]
          },
          "then": {
            "properties": {
              "end": {
                "type": "object",
                "properties": {
                  "character": {
                    "type": "integer",
                    "minimum": {
                      "$data": "2/start/character"
                    }
                  }
                }
              }
            }
          }
        }
      ]
    },
    "ideActionType": {
      "type": "string",
      "enum": [
        "getContextSnapshot",
        "openWorkspaceFile",
        "revealWorkspaceRange"
      ]
    },
    "ideActionResultPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "message",
        "cloudRequired"
      ],
      "allOf": [
        {
          "if": {
            "properties": {
              "status": {
                "const": "succeeded"
              }
            },
            "required": [
              "status"
            ]
          },
          "then": {
            "properties": {
              "action": {
                "$ref": "#/$defs/ideActionType"
              }
            },
            "required": [
              "action"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "status": {
                "const": "succeeded"
              },
              "action": {
                "const": "getContextSnapshot"
              }
            },
            "required": [
              "status",
              "action"
            ]
          },
          "then": {
            "properties": {
              "workspaceRelativePath": false,
              "range": false,
              "context": true
            },
            "required": [
              "context"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "status": {
                "const": "succeeded"
              },
              "action": {
                "const": "openWorkspaceFile"
              }
            },
            "required": [
              "status",
              "action"
            ]
          },
          "then": {
            "properties": {
              "workspaceRelativePath": {
                "$ref": "#/$defs/safeRelativePath"
              },
              "range": false,
              "context": false
            },
            "required": [
              "workspaceRelativePath"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "status": {
                "const": "succeeded"
              },
              "action": {
                "const": "revealWorkspaceRange"
              }
            },
            "required": [
              "status",
              "action"
            ]
          },
          "then": {
            "properties": {
              "workspaceRelativePath": {
                "$ref": "#/$defs/safeRelativePath"
              },
              "range": {
                "$ref": "#/$defs/range"
              },
              "context": false
            },
            "required": [
              "workspaceRelativePath",
              "range"
            ]
          }
        }
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "succeeded",
            "rejected",
            "unavailable",
            "failed"
          ]
        },
        "message": {
          "$ref": "#/$defs/safeMessage"
        },
        "cloudRequired": {
          "type": "boolean",
          "const": false
        },
        "action": {
          "$ref": "#/$defs/ideActionType"
        },
        "workspaceRelativePath": {
          "$ref": "#/$defs/safeRelativePath"
        },
        "range": {
          "$ref": "#/$defs/range"
        },
        "context": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "source",
            "hasActiveEditor",
            "workspaceFolderCount"
          ],
          "properties": {
            "source": {
              "type": "string",
              "enum": [
                "vscode"
              ]
            },
            "hasActiveEditor": {
              "type": "boolean"
            },
            "workspaceFolderCount": {
              "type": "integer",
              "minimum": 0,
              "maximum": 100
            }
          }
        }
      }
    },
    "ideActionProgressPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "phase",
        "status",
        "summary",
        "cloudRequired"
      ],
      "allOf": [
        {
          "if": {
            "properties": {
              "phase": {
                "const": "queued"
              }
            },
            "required": [
              "phase"
            ]
          },
          "then": {
            "properties": {
              "status": {
                "const": "pending"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "phase": {
                "enum": [
                  "checkingPolicy",
                  "running"
                ]
              }
            },
            "required": [
              "phase"
            ]
          },
          "then": {
            "properties": {
              "status": {
                "const": "inProgress"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "phase": {
                "const": "completed"
              }
            },
            "required": [
              "phase"
            ]
          },
          "then": {
            "properties": {
              "status": {
                "enum": [
                  "succeeded",
                  "rejected",
                  "unavailable",
                  "failed"
                ]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "status": {
                "const": "succeeded"
              }
            },
            "required": [
              "status"
            ]
          },
          "then": {
            "properties": {
              "action": {
                "$ref": "#/$defs/ideActionType"
              }
            },
            "required": [
              "action"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "status": {
                "const": "succeeded"
              },
              "action": {
                "const": "getContextSnapshot"
              }
            },
            "required": [
              "status",
              "action"
            ]
          },
          "then": {
            "properties": {
              "workspaceRelativePath": false,
              "range": false,
              "context": false
            }
          }
        },
        {
          "if": {
            "properties": {
              "status": {
                "const": "succeeded"
              },
              "action": {
                "const": "openWorkspaceFile"
              }
            },
            "required": [
              "status",
              "action"
            ]
          },
          "then": {
            "properties": {
              "workspaceRelativePath": {
                "$ref": "#/$defs/safeRelativePath"
              },
              "range": false,
              "context": false
            },
            "required": [
              "workspaceRelativePath"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "status": {
                "const": "succeeded"
              },
              "action": {
                "const": "revealWorkspaceRange"
              }
            },
            "required": [
              "status",
              "action"
            ]
          },
          "then": {
            "properties": {
              "workspaceRelativePath": {
                "$ref": "#/$defs/safeRelativePath"
              },
              "range": {
                "$ref": "#/$defs/range"
              },
              "context": false
            },
            "required": [
              "workspaceRelativePath",
              "range"
            ]
          }
        }
      ],
      "properties": {
        "phase": {
          "type": "string",
          "enum": [
            "queued",
            "checkingPolicy",
            "running",
            "completed"
          ]
        },
        "status": {
          "type": "string",
          "enum": [
            "pending",
            "inProgress",
            "succeeded",
            "rejected",
            "unavailable",
            "failed"
          ]
        },
        "summary": {
          "$ref": "#/$defs/safeMessage"
        },
        "cloudRequired": {
          "type": "boolean",
          "const": false
        },
        "action": {
          "$ref": "#/$defs/ideActionType"
        },
        "workspaceRelativePath": {
          "$ref": "#/$defs/safeRelativePath"
        },
        "range": {
          "$ref": "#/$defs/range"
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "type": {
            "const": "host.ready"
          }
        },
        "required": [
          "type"
        ]
      },
      "then": {
        "required": [
          "payload"
        ],
        "properties": {
          "payload": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "runtimeUrl": {
                "type": "string",
                "format": "uri",
                "maxLength": 2048,
                "pattern": "^https?://(?:127\\.0\\.0\\.1|localhost|\\[::1\\]):(?:[1-9][0-9]{0,3}|[1-5][0-9]{4}|6[0-4][0-9]{3}|65[0-4][0-9]{2}|655[0-2][0-9]|6553[0-5])/?$"
              },
              "sessionToken": {
                "type": "string",
                "minLength": 1,
                "maxLength": 512,
                "pattern": "^(?!.*(?:[Bb][Ee][Aa][Rr][Ee][Rr]|[Aa][Pp][Ii][_-]?[Kk][Ee][Yy]|[Ss][Ee][Cc][Rr][Ee][Tt]|[Pp][Aa][Ss][Ss][Ww][Oo][Rr][Dd]|[Ss][Kk]-(?:[Pp][Rr][Oo][Jj]-)?[A-Za-z0-9_-]{8,}))[A-Za-z0-9._~+/=-]+$"
              },
              "productId": {
                "type": "string",
                "minLength": 1,
                "maxLength": 64,
                "pattern": "^(?!.*(?:[Aa][Uu][Tt][Hh]|[Bb][Ee][Aa][Rr][Ee][Rr]|[Aa][Pp][Ii][_-]?[Kk][Ee][Yy]|[Tt][Oo][Kk][Ee][Nn]|[Ss][Ee][Cc][Rr][Ee][Tt]|[Ss][Kk]-(?:[Pp][Rr][Oo][Jj]-)?[A-Za-z0-9_-]{8,}))[A-Za-z0-9][A-Za-z0-9_.-]{0,63}$"
              },
              "displayName": {
                "type": "string",
                "minLength": 1,
                "maxLength": 80,
