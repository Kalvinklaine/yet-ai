{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.yet-ai.example/contracts/bridge/host-message.schema.json",
  "title": "IDE Host to GUI Message",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "type"],
  "properties": {
    "version": {
      "type": "string",
      "minLength": 1
    },
    "type": {
      "type": "string",
      "enum": [
        "host.ready",
        "host.themeChanged",
        "host.activeFileChanged",
        "host.selectionChanged",
        "host.workspaceChanged",
        "host.toolResult",
        "host.openedFromCommand"
      ]
    },
    "requestId": {
      "type": "string",
      "minLength": 1
    },
    "payload": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
