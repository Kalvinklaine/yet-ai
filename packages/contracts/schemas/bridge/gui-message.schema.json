{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.yet-ai.example/contracts/bridge/gui-message.schema.json",
  "title": "GUI to IDE Host Message",
  "description": "Strict GUI readiness, current read-only/navigation controlled IDE action requests, and confirmed edit proposal messages only. Controlled IDE actions are local-only read/context/navigation requests and do not grant writes, shell-like actions, tasks, git, arbitrary tools, or autonomous file reads.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "type"
  ],
  "properties": {
    "version": {
      "type": "string",
      "const": "2026-05-15"
    },
    "type": {
      "type": "string",
      "enum": [
        "gui.ready",
        "gui.unloaded",
        "gui.ideActionRequest",
        "gui.applyWorkspaceEditRequest",
        "gui.controlledAgentFileReadRequest"
      ]
    },
    "requestId": {
      "$ref": "#/$defs/requestId"
    },
    "payload": {
      "type": "object"
    }
  },
  "$defs": {
    "requestId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^(?!.*(?:[Aa][Uu][Tt][Hh][Oo][Rr][Ii][Zz][Aa][Tt][Ii][Oo][Nn]|[Bb][Ee][Aa][Rr][Ee][Rr]|[Aa][Pp][Ii][-_]?[Kk][Ee][Yy]|[Tt][Oo][Kk][Ee][Nn]|[Ss][Ee][Cc][Rr][Ee][Tt]|[Aa][Cc][Cc][Ee][Ss][Ss][-_]?[Tt][Oo][Kk][Ee][Nn]|[Pp][Rr][Oo][Vv][Ii][Dd][Ee][Rr][-_]?[Kk][Ee][Yy]|[Oo][Pp][Ee][Nn][Aa][Ii][-_]?[Aa][Pp][Ii][-_]?[Kk][Ee][Yy]|[Ss][Kk]-(?:[Pp][Rr][Oo][Jj]-)?[A-Za-z0-9_-]{8,}))[A-Za-z0-9][A-Za-z0-9_.-]{0,127}$"
    },
    "safeRelativePath": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512,
      "pattern": "^(?!/)(?!~)(?!.*%)(?!.*\\\\)(?!.*:)(?!.*[?#])(?!.*(?:^|/)\\.\\.?(?:/|$))(?!.*//)(?!.*\\/$)(?!.*(?:^|/)(?:[Aa][Uu][Tt][Hh]|[Aa][Uu][Tt][Hh][Oo][Rr][Ii][Zz][Aa][Tt][Ii][Oo][Nn]|[Bb][Ee][Aa][Rr][Ee][Rr]|[Cc][Oo][Oo][Kk][Ii][Ee]|[Cc][Rr][Ee][Dd][Ee][Nn][Tt][Ii][Aa][Ll][Ss]?|[Pp][Aa][Ss][Ss][Ww][Oo][Rr][Dd]|[Ss][Ee][Cc][Rr][Ee][Tt]|[Tt][Oo][Kk][Ee][Nn]|[Aa][Cc][Cc][Ee][Ss][Ss][_-]?[Tt][Oo][Kk][Ee][Nn]|[Aa][Pp][Ii][_-]?[Kk][Ee][Yy])(?:[._-]|/|$))(?!.*(?:^|[._-])(?:[Aa][Uu][Tt][Hh]|[Cc][Rr][Ee][Dd][Ee][Nn][Tt][Ii][Aa][Ll][Ss]?|[Pp][Aa][Ss][Ss][Ww][Oo][Rr][Dd]|[Ss][Ee][Cc][Rr][Ee][Tt]|[Tt][Oo][Kk][Ee][Nn]|[Aa][Cc][Cc][Ee][Ss][Ss][_-]?[Tt][Oo][Kk][Ee][Nn]|[Aa][Pp][Ii][_-]?[Kk][Ee][Yy])(?:[._-]|$))(?!.*(?:^|/)[Ss][Kk]-(?:[Pp][Rr][Oo][Jj]-)?[A-Za-z0-9_-]{8,})[^\\u0000-\\u001f\\u007f-\\u009f]+$"
    },
    "safeSummary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1000,
      "pattern": "^(?!.*(?:[\u0000-\u001f-]|[Aa][Uu][Tt][Hh][Oo][Rr][Ii][Zz][Aa][Tt][Ii][Oo][Nn]|[Bb][Ee][Aa][Rr][Ee][Rr]|[Cc][Oo][Oo][Kk][Ii][Ee]|[Aa][Pp][Ii][_-]?[Kk][Ee][Yy]|[Tt][Oo][Kk][Ee][Nn]|[Ss][Ee][Cc][Rr][Ee][Tt]|[Pp][Aa][Ss][Ss][Ww][Oo][Rr][Dd]|[Pp][Rr][Ii][Vv][Aa][Tt][Ee][_-]?[Pp][Aa][Tt][Hh]|[Pp][Rr][Oo][Vv][Ii][Dd][Ee][Rr][_-]?[Rr][Ee][Ss][Pp][Oo][Nn][Ss][Ee]|[Rr][Aa][Ww][_-]?[Pp][Rr][Oo][Mm][Pp][Tt]|[Ff][Ii][Ll][Ee][_-]?[Cc][Oo][Nn][Tt][Ee][Nn][Tt]|/[Uu][Ss][Ee][Rr][Ss](?=/|$|[^A-Za-z0-9_])|/[Hh][Oo][Mm][Ee](?=/|$|[^A-Za-z0-9_])|/[Tt][Mm][Pp](?=/|$|[^A-Za-z0-9_])|/[Vv][Aa][Rr](?=/|$|[^A-Za-z0-9_])|/[Ee][Tt][Cc](?=/|$|[^A-Za-z0-9_])|/[Oo][Pp][Tt](?=/|$|[^A-Za-z0-9_])|/[Mm][Nn][Tt](?=/|$|[^A-Za-z0-9_])|/[Vv][Oo][Ll][Uu][Mm][Ee][Ss](?=/|$|[^A-Za-z0-9_])|/[Pp][Rr][Ii][Vv][Aa][Tt][Ee](?=/|$|[^A-Za-z0-9_])|[A-Za-z]:(?:/|\\\\)|~(?:/|\\\\)|(?:^|[^A-Za-z0-9_-])[Ss][Kk]-(?:[Pp][Rr][Oo][Jj]-)?[A-Za-z0-9_-]{8,})).*$"
    },
    "position": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "line",
        "character"
      ],
      "properties": {
        "line": {
          "type": "integer",
          "minimum": 0,
          "maximum": 1000000
        },
        "character": {
          "type": "integer",
          "minimum": 0,
          "maximum": 1000000
        }
      }
    },
    "range": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "start",
        "end"
      ],
      "properties": {
        "start": {
          "$ref": "#/$defs/position"
        },
        "end": {
          "$ref": "#/$defs/position"
        }
      },
      "allOf": [
        {
          "properties": {
            "end": {
              "type": "object",
              "properties": {
                "line": {
                  "type": "integer",
                  "minimum": {
                    "$data": "2/start/line"
                  }
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "start": {
                "type": "object",
                "properties": {
                  "line": true
                },
                "required": [
                  "line"
                ]
              },
              "end": {
                "type": "object",
                "properties": {
                  "line": {
                    "type": "integer",
                    "const": {
                      "$data": "2/start/line"
                    }
                  }
                },
                "required": [
                  "line"
                ]
              }
            },
            "required": [
              "start",
              "end"
            ]
          },
          "then": {
            "properties": {
              "end": {
                "type": "object",
                "properties": {
                  "character": {
                    "type": "integer",
                    "minimum": {
                      "$data": "2/start/character"
                    }
                  }
                }
              }
            }
          }
        }
      ]
    },
    "textReplacement": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "range",
        "replacementText"
      ],
      "properties": {
        "range": {
          "$ref": "#/$defs/range"
        },
        "replacementText": {
          "type": "string",
          "maxLength": 8192
        }
      }
    },
    "fileTextEdits": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "workspaceRelativePath",
        "textReplacements"
      ],
      "properties": {
        "workspaceRelativePath": {
          "$ref": "#/$defs/safeRelativePath"
        },
        "textReplacements": {
          "type": "array",
          "minItems": 1,
          "maxItems": 16,
          "items": {
            "$ref": "#/$defs/textReplacement"
          }
        }
      }
    },
    "applyWorkspaceEditPayload": {
      "type": "object",
      "additionalProperties": false,
      "maxTotalReplacementText": 32768,
      "uniquePathsInEdits": true,
      "required": [
        "requiresUserConfirmation",
        "summary",
        "edits"
      ],
      "properties": {
        "requiresUserConfirmation": {
          "type": "boolean",
          "const": true
        },
        "summary": {
          "$ref": "#/$defs/safeSummary"
        },
        "cloudRequired": {
          "type": "boolean",
          "const": false
        },
        "edits": {
          "type": "array",
          "minItems": 1,
          "maxItems": 4,
          "items": {
            "$ref": "#/$defs/fileTextEdits"
          }
        }
      }
    },
    "ideActionType": {
      "type": "string",
      "enum": [
        "getContextSnapshot",
        "openWorkspaceFile",
        "revealWorkspaceRange",
        "getActiveFileExcerpt",
        "runVerificationCommand",
        "searchWorkspaceSnippets"
      ]
    },
    "ideActionRequestPayload": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "action"
          ],
          "properties": {
            "action": {
              "const": "getContextSnapshot"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "action"
          ],
          "properties": {
            "action": {
              "const": "getActiveFileExcerpt"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "action",
            "workspaceRelativePath"
          ],
          "properties": {
            "action": {
              "const": "openWorkspaceFile"
            },
            "workspaceRelativePath": {
              "$ref": "#/$defs/safeRelativePath"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "action",
            "workspaceRelativePath",
            "range"
          ],
          "properties": {
            "action": {
              "const": "revealWorkspaceRange"
            },
            "workspaceRelativePath": {
              "$ref": "#/$defs/safeRelativePath"
            },
            "range": {
              "$ref": "#/$defs/range"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "action",
            "commandId",
            "preset"
          ],
          "properties": {
            "action": {
              "const": "runVerificationCommand"
            },
            "commandId": {
              "$ref": "#/$defs/verificationCommandId"
            },
            "preset": {
              "$ref": "#/$defs/verificationPresetMetadata"
            }
          },
          "allOf": [
            {
              "properties": {
                "preset": {
                  "type": "object",
                  "properties": {
                    "commandId": {
                      "const": {
                        "$data": "2/commandId"
                      }
                    }
                  }
                }
              }
            }
          ]
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "action",
            "query"
          ],
          "properties": {
            "action": {
              "const": "searchWorkspaceSnippets"
            },
            "query": {
              "$ref": "#/$defs/workspaceSnippetSearchQuery"
            }
          }
        }
      ]
    },
    "verificationCommandId": {
      "type": "string",
      "enum": [
        "repository-check",
        "gui-app-tests",
        "engine-chat-tests"
      ]
    },
    "verificationPresetLabel": {
      "type": "string",
      "enum": [
        "Repository check",
        "GUI app tests",
        "Engine chat tests"
      ]
    },
    "verificationPresetDescription": {
      "type": "string",
      "enum": [
        "Run the repository validation gate.",
        "Run the focused GUI application test gate.",
        "Run the focused engine chat test gate."
      ]
    },
    "verificationPresetRiskLevel": {
      "type": "string",
      "enum": [
        "low",
        "medium"
      ]
    },
    "verificationPresetExpectedDuration": {
      "type": "string",
      "enum": [
        "Usually under 1 minute",
        "Usually 1 to 5 minutes",
        "Usually 5 to 10 minutes"
      ]
    },
    "verificationPresetCwdPolicyLabel": {
      "type": "string",
      "const": "Repository root"
    },
    "verificationPresetOutputBoundLabel": {
      "type": "string",
      "const": "Sanitized tail only"
    },
    "verificationPresetMetadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "commandId",
        "label",
        "description",
        "riskLevel",
        "expectedDuration",
        "cwdPolicyLabel",
        "outputBoundLabel"
      ],
      "properties": {
        "commandId": {
          "$ref": "#/$defs/verificationCommandId"
        },
        "label": {
          "$ref": "#/$defs/verificationPresetLabel"
        },
        "description": {
          "$ref": "#/$defs/verificationPresetDescription"
        },
        "riskLevel": {
          "$ref": "#/$defs/verificationPresetRiskLevel"
        },
        "expectedDuration": {
          "$ref": "#/$defs/verificationPresetExpectedDuration"
        },
        "cwdPolicyLabel": {
          "$ref": "#/$defs/verificationPresetCwdPolicyLabel"
        },
        "outputBoundLabel": {
          "$ref": "#/$defs/verificationPresetOutputBoundLabel"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "commandId": {
                "const": "repository-check"
              }
            },
            "required": [
              "commandId"
            ]
          },
          "then": {
            "properties": {
              "label": {
                "const": "Repository check"
              },
              "description": {
                "const": "Run the repository validation gate."
              },
              "riskLevel": {
                "const": "medium"
              },
              "expectedDuration": {
                "const": "Usually 1 to 5 minutes"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "commandId": {
                "const": "gui-app-tests"
              }
            },
            "required": [
              "commandId"
            ]
          },
          "then": {
            "properties": {
              "label": {
                "const": "GUI app tests"
              },
              "description": {
                "const": "Run the focused GUI application test gate."
              },
              "riskLevel": {
                "const": "medium"
              },
              "expectedDuration": {
                "const": "Usually 5 to 10 minutes"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "commandId": {
                "const": "engine-chat-tests"
              }
            },
            "required": [
              "commandId"
            ]
          },
          "then": {
            "properties": {
              "label": {
                "const": "Engine chat tests"
              },
              "description": {
                "const": "Run the focused engine chat test gate."
              },
              "riskLevel": {
                "const": "low"
              },
              "expectedDuration": {
                "const": "Usually under 1 minute"
              }
            }
          }
        }
      ]
    },
    "workspaceSnippetSearchQuery": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120,
      "pattern": "^(?!.*(?:[\\u0000-\\u001f\\u007f-\\u009f]|[*/\\\\~]|\\.\\.|[{}[\\]()^$+?|]|[;&`$<>]|\\b(?:cwd|env|shell|git|tool|provider|model|apiKey|requestId|assistant|regex|glob|path)\\b|[Aa][Uu][Tt][Hh][Oo][Rr][Ii][Zz][Aa][Tt][Ii][Oo][Nn]|[Bb][Ee][Aa][Rr][Ee][Rr]|[Cc][Oo][Oo][Kk][Ii][Ee]|[Aa][Pp][Ii][_-]?[Kk][Ee][Yy]|[Tt][Oo][Kk][Ee][Nn]|[Ss][Ee][Cc][Rr][Ee][Tt]|[Pp][Aa][Ss][Ss][Ww][Oo][Rr][Dd]|[Pp][Rr][Ii][Vv][Aa][Tt][Ee][_-]?[Pp][Aa][Tt][Hh]|[A-Za-z]:|(?:^|[^A-Za-z0-9_-])[Ss][Kk]-(?:[Pp][Rr][Oo][Jj]-)?[A-Za-z0-9_-]{8,}))[\\s\\S]*\\S[\\s\\S]*$"
    },
    "controlledAgentFileReadPath": {
      "type": "string",
      "minLength": 1,
      "maxLength": 180,
      "pattern": "^(?!/)(?![A-Za-z]:)(?!~)(?!.*(?:^|/)\\.)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*//)(?!.*[\\\\:*?\"<>|{}\\[\\]$^+])(?!(?:^|.*/)(?:node_modules|vendor|dist|build|out|target|coverage|__pycache__|generated|tmp|temp|secrets?|credentials?|private)(?:/|$))[A-Za-z0-9][A-Za-z0-9._-]*(?:/[A-Za-z0-9][A-Za-z0-9._-]*)*$"
    },
    "controlledAgentFileReadRequestPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "requestIdMintedBy",
        "source",
        "assistantMinted",
        "controlledWorkspaceId",
        "runId",
        "workspaceRelativePath",
        "maxBytes",
        "maxLines",
        "allowBody",
        "singleFileOnly",
        "recursive",
        "globAllowed",
        "regexAllowed",
        "indexingAllowed"
      ],
      "properties": {
        "requestIdMintedBy": {
          "type": "string",
          "enum": [
            "gui",
            "host"
          ]
        },
        "source": {
          "type": "string",
          "enum": [
            "gui",
            "host"
          ]
        },
        "assistantMinted": {
          "type": "boolean",
          "const": false
        },
        "controlledWorkspaceId": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80,
          "pattern": "^(?!assistant(?:[._-]|$))(?!.*(?:[Aa][Ss][Ss][Ii][Ss][Tt][Aa][Nn][Tt]|[Ss][Kk]-(?:[Pp][Rr][Oo][Jj]-)?))[A-Za-z0-9][A-Za-z0-9._-]*$"
        },
        "runId": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80,
          "pattern": "^(?!assistant(?:[._-]|$))(?!.*(?:[Aa][Ss][Ss][Ii][Ss][Tt][Aa][Nn][Tt]|[Ss][Kk]-(?:[Pp][Rr][Oo][Jj]-)?))[A-Za-z0-9][A-Za-z0-9._-]*$"
        },
        "runtimeSessionId": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80,
          "pattern": "^(?!assistant(?:[._-]|$))(?!.*(?:[Aa][Ss][Ss][Ii][Ss][Tt][Aa][Nn][Tt]|[Ss][Kk]-(?:[Pp][Rr][Oo][Jj]-)?))[A-Za-z0-9][A-Za-z0-9._-]*$"
        },
        "sessionId": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80,
          "pattern": "^(?!assistant(?:[._-]|$))(?!.*(?:[Aa][Ss][Ss][Ii][Ss][Tt][Aa][Nn][Tt]|[Ss][Kk]-(?:[Pp][Rr][Oo][Jj]-)?))[A-Za-z0-9][A-Za-z0-9._-]*$"
        },
        "workspaceRelativePath": {
          "$ref": "#/$defs/controlledAgentFileReadPath"
        },
        "maxBytes": {
          "type": "integer",
          "minimum": 1,
          "maximum": 8192
        },
        "maxLines": {
          "type": "integer",
          "minimum": 1,
          "maximum": 240
        },
        "allowBody": {
          "type": "boolean"
        },
        "singleFileOnly": {
          "type": "boolean",
          "const": true
        },
        "recursive": {
          "type": "boolean",
          "const": false
        },
        "globAllowed": {
          "type": "boolean",
          "const": false
        },
        "regexAllowed": {
          "type": "boolean",
          "const": false
        },
        "indexingAllowed": {
          "type": "boolean",
          "const": false
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "type": {
            "const": "gui.ready"
          }
        },
        "required": [
          "type"
        ]
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "supportedBridgeVersion": {
                "type": "string",
                "const": "2026-05-15"
              },
              "frameNonce": {
                "type": "string",
                "pattern": "^[0-9a-f]{32}$"
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "gui.unloaded"
          }
        },
        "required": [
          "type"
        ]
      },
      "then": {
        "not": {
          "properties": {
            "requestId": true
          },
          "required": [
            "requestId"
          ]
        },
        "properties": {
          "payload": {
            "type": "object",
            "additionalProperties": false
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "gui.ideActionRequest"
          }
        },
        "required": [
          "type"
        ]
      },
      "then": {
        "required": [
          "requestId",
          "payload"
        ],
        "properties": {
          "requestId": {
            "$ref": "#/$defs/requestId"
          },
          "payload": {
            "$ref": "#/$defs/ideActionRequestPayload"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "gui.applyWorkspaceEditRequest"
          }
        },
        "required": [
          "type"
        ]
      },
      "then": {
        "required": [
          "requestId",
          "payload"
        ],
        "properties": {
          "requestId": {
            "$ref": "#/$defs/requestId"
          },
          "payload": {
            "$ref": "#/$defs/applyWorkspaceEditPayload"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "gui.controlledAgentFileReadRequest"
          }
        },
        "required": [
          "type"
        ]
      },
      "then": {
        "required": [
          "requestId",
          "payload"
        ],
        "properties": {
          "requestId": {
            "$ref": "#/$defs/requestId"
          },
          "payload": {
            "$ref": "#/$defs/controlledAgentFileReadRequestPayload"
          }
        }
      }
    }
  ]
}
