{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.yet-ai.example/contracts/bridge/gui-message.schema.json",
  "title": "GUI to IDE Host Message",
  "description": "Strict GUI readiness plus future/current confirmed edit proposal messages only. File open/reveal, unconfirmed workspace edits, notifications, context requests, shell-like actions, tasks, git, and IDE tool execution remain disabled until strict schemas, policy, request correlation, and confirmation are implemented.",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "type"],
  "properties": {
    "version": {
      "type": "string",
      "const": "2026-05-15"
    },
    "type": {
      "type": "string",
      "enum": ["gui.ready", "gui.applyWorkspaceEditRequest"]
    },
    "requestId": {
      "$ref": "#/$defs/requestId"
    },
    "payload": {
      "type": "object"
    }
  },
  "$defs": {
    "requestId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[^\\u0000-\\u001f\\u007f-\\u009f]+$"
    },
    "safeRelativePath": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512,
      "pattern": "^(?!/)(?!~)(?!.*%)(?!.*\\\\)(?!.*:)(?!.*[?#])(?!.*(?:^|/)\\.\\.?(?:/|$))(?!.*//)(?!.*\\/$)[^\\u0000-\\u001f\\u007f-\\u009f]+$"
    },
    "safeSummary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1000,
      "pattern": "^(?!.*(?:[Aa][Uu][Tt][Hh][Oo][Rr][Ii][Zz][Aa][Tt][Ii][Oo][Nn]|[Bb][Ee][Aa][Rr][Ee][Rr]|[Cc][Oo][Oo][Kk][Ii][Ee]|[Aa][Pp][Ii][_-]?[Kk][Ee][Yy]|[Tt][Oo][Kk][Ee][Nn]|[Ss][Ee][Cc][Rr][Ee][Tt]|[Pp][Aa][Ss][Ss][Ww][Oo][Rr][Dd]|[Pp][Rr][Ii][Vv][Aa][Tt][Ee][_-]?[Pp][Aa][Tt][Hh]|[Pp][Rr][Oo][Vv][Ii][Dd][Ee][Rr][_-]?[Rr][Ee][Ss][Pp][Oo][Nn][Ss][Ee]|[Rr][Aa][Ww][_-]?[Pp][Rr][Oo][Mm][Pp][Tt]|[Ff][Ii][Ll][Ee][_-]?[Cc][Oo][Nn][Tt][Ee][Nn][Tt]|/[Uu][Ss][Ee][Rr][Ss]/|/[Hh][Oo][Mm][Ee]/|/[Tt][Mm][Pp]/|/[Vv][Aa][Rr]/|/[Vv][Oo][Ll][Uu][Mm][Ee][Ss]/|/[Pp][Rr][Ii][Vv][Aa][Tt][Ee]/|[A-Za-z]:(?:/|\\\\)|~(?:/|\\\\)|(?:^|[^A-Za-z0-9_-])sk-(?:proj-)?[A-Za-z0-9_-]{8,})).*$"
    },
    "position": {
      "type": "object",
      "additionalProperties": false,
      "required": ["line", "character"],
      "properties": {
        "line": {
          "type": "integer",
          "minimum": 0,
          "maximum": 1000000
        },
        "character": {
          "type": "integer",
          "minimum": 0,
          "maximum": 1000000
        }
      }
    },
    "range": {
      "type": "object",
      "additionalProperties": false,
      "required": ["start", "end"],
      "properties": {
        "start": {
          "$ref": "#/$defs/position"
        },
        "end": {
          "$ref": "#/$defs/position"
        }
      },
      "allOf": [
        {
          "properties": {
            "end": {
              "type": "object",
              "properties": {
                "line": {
                  "type": "integer",
                  "minimum": {
                    "$data": "2/start/line"
                  }
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "start": {
                "type": "object",
                "properties": {
                  "line": true
                },
                "required": ["line"]
              },
              "end": {
                "type": "object",
                "properties": {
                  "line": {
                    "type": "integer",
                    "const": {
                      "$data": "2/start/line"
                    }
                  }
                },
                "required": ["line"]
              }
            },
            "required": ["start", "end"]
          },
          "then": {
            "properties": {
              "end": {
                "type": "object",
                "properties": {
                  "character": {
                    "type": "integer",
                    "minimum": {
                      "$data": "2/start/character"
                    }
                  }
                }
              }
            }
          }
        }
      ]
    },
    "textReplacement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["range", "replacementText"],
      "properties": {
        "range": {
          "$ref": "#/$defs/range"
        },
        "replacementText": {
          "type": "string",
          "maxLength": 8192
        }
      }
    },
    "fileTextEdits": {
      "type": "object",
      "additionalProperties": false,
      "required": ["workspaceRelativePath", "textReplacements"],
      "properties": {
        "workspaceRelativePath": {
          "$ref": "#/$defs/safeRelativePath"
        },
        "textReplacements": {
          "type": "array",
          "minItems": 1,
          "maxItems": 16,
          "items": {
            "$ref": "#/$defs/textReplacement"
          }
        }
      }
    },
    "applyWorkspaceEditPayload": {
      "type": "object",
      "additionalProperties": false,
      "maxTotalReplacementText": 32768,
      "required": ["requiresUserConfirmation", "summary", "edits"],
      "properties": {
        "requiresUserConfirmation": {
          "type": "boolean",
          "const": true
        },
        "summary": {
          "$ref": "#/$defs/safeSummary"
        },
        "cloudRequired": {
          "type": "boolean",
          "const": false
        },
        "edits": {
          "type": "array",
          "minItems": 1,
          "maxItems": 4,
          "items": {
            "$ref": "#/$defs/fileTextEdits"
          }
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "type": {
            "const": "gui.ready"
          }
        },
        "required": ["type"]
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "supportedBridgeVersion": {
                "type": "string",
                "const": "2026-05-15"
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "gui.applyWorkspaceEditRequest"
          }
        },
        "required": ["type"]
      },
      "then": {
        "required": ["requestId", "payload"],
        "properties": {
          "requestId": {
            "$ref": "#/$defs/requestId"
          },
          "payload": {
            "$ref": "#/$defs/applyWorkspaceEditPayload"
          }
        }
      }
    }
  ]
}
