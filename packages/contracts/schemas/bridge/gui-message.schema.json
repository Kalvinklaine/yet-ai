{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.yet-ai.example/contracts/bridge/gui-message.schema.json",
  "title": "GUI to IDE Host Message",
  "description": "Strict GUI readiness, current read-only/navigation controlled IDE action requests, and confirmed edit proposal messages only. Controlled IDE actions are local-only read/context/navigation requests and do not grant writes, shell-like actions, tasks, git, arbitrary tools, or autonomous file reads.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "type"
  ],
  "properties": {
    "version": {
      "type": "string",
      "const": "2026-05-15"
    },
    "type": {
      "type": "string",
      "enum": [
        "gui.ready",
        "gui.unloaded",
        "gui.ideActionRequest",
        "gui.applyWorkspaceEditRequest"
      ]
    },
    "requestId": {
      "$ref": "#/$defs/requestId"
    },
    "payload": {
      "type": "object"
    }
  },
  "$defs": {
    "requestId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^(?!.*(?:[Aa][Uu][Tt][Hh][Oo][Rr][Ii][Zz][Aa][Tt][Ii][Oo][Nn]|[Bb][Ee][Aa][Rr][Ee][Rr]|[Aa][Pp][Ii][-_]?[Kk][Ee][Yy]|[Tt][Oo][Kk][Ee][Nn]|[Ss][Ee][Cc][Rr][Ee][Tt]|[Aa][Cc][Cc][Ee][Ss][Ss][-_]?[Tt][Oo][Kk][Ee][Nn]|[Pp][Rr][Oo][Vv][Ii][Dd][Ee][Rr][-_]?[Kk][Ee][Yy]|[Oo][Pp][Ee][Nn][Aa][Ii][-_]?[Aa][Pp][Ii][-_]?[Kk][Ee][Yy]|[Ss][Kk]-(?:[Pp][Rr][Oo][Jj]-)?[A-Za-z0-9_-]{8,}))[A-Za-z0-9][A-Za-z0-9_.-]{0,127}$"
    },
    "safeRelativePath": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512,
      "pattern": "^(?!/)(?!~)(?!.*%)(?!.*\\\\)(?!.*:)(?!.*[?#])(?!.*(?:^|/)\\.\\.?(?:/|$))(?!.*//)(?!.*\\/$)(?!.*(?:^|/)(?:[Aa][Uu][Tt][Hh]|[Aa][Uu][Tt][Hh][Oo][Rr][Ii][Zz][Aa][Tt][Ii][Oo][Nn]|[Bb][Ee][Aa][Rr][Ee][Rr]|[Cc][Oo][Oo][Kk][Ii][Ee]|[Cc][Rr][Ee][Dd][Ee][Nn][Tt][Ii][Aa][Ll][Ss]?|[Pp][Aa][Ss][Ss][Ww][Oo][Rr][Dd]|[Ss][Ee][Cc][Rr][Ee][Tt]|[Tt][Oo][Kk][Ee][Nn]|[Aa][Cc][Cc][Ee][Ss][Ss][_-]?[Tt][Oo][Kk][Ee][Nn]|[Aa][Pp][Ii][_-]?[Kk][Ee][Yy])(?:[._-]|/|$))(?!.*(?:^|[._-])(?:[Aa][Uu][Tt][Hh]|[Cc][Rr][Ee][Dd][Ee][Nn][Tt][Ii][Aa][Ll][Ss]?|[Pp][Aa][Ss][Ss][Ww][Oo][Rr][Dd]|[Ss][Ee][Cc][Rr][Ee][Tt]|[Tt][Oo][Kk][Ee][Nn]|[Aa][Cc][Cc][Ee][Ss][Ss][_-]?[Tt][Oo][Kk][Ee][Nn]|[Aa][Pp][Ii][_-]?[Kk][Ee][Yy])(?:[._-]|$))(?!.*(?:^|/)[Ss][Kk]-(?:[Pp][Rr][Oo][Jj]-)?[A-Za-z0-9_-]{8,})[^\\u0000-\\u001f\\u007f-\\u009f]+$"
    },
    "safeSummary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1000,
      "pattern": "^(?!.*(?:[\u0000-\u001f\u007f-\u009f]|[Aa][Uu][Tt][Hh][Oo][Rr][Ii][Zz][Aa][Tt][Ii][Oo][Nn]|[Bb][Ee][Aa][Rr][Ee][Rr]|[Cc][Oo][Oo][Kk][Ii][Ee]|[Aa][Pp][Ii][_-]?[Kk][Ee][Yy]|[Tt][Oo][Kk][Ee][Nn]|[Ss][Ee][Cc][Rr][Ee][Tt]|[Pp][Aa][Ss][Ss][Ww][Oo][Rr][Dd]|[Pp][Rr][Ii][Vv][Aa][Tt][Ee][_-]?[Pp][Aa][Tt][Hh]|[Pp][Rr][Oo][Vv][Ii][Dd][Ee][Rr][_-]?[Rr][Ee][Ss][Pp][Oo][Nn][Ss][Ee]|[Rr][Aa][Ww][_-]?[Pp][Rr][Oo][Mm][Pp][Tt]|[Ff][Ii][Ll][Ee][_-]?[Cc][Oo][Nn][Tt][Ee][Nn][Tt]|/[Uu][Ss][Ee][Rr][Ss](?=/|$|[^A-Za-z0-9_])|/[Hh][Oo][Mm][Ee](?=/|$|[^A-Za-z0-9_])|/[Tt][Mm][Pp](?=/|$|[^A-Za-z0-9_])|/[Vv][Aa][Rr](?=/|$|[^A-Za-z0-9_])|/[Ee][Tt][Cc](?=/|$|[^A-Za-z0-9_])|/[Oo][Pp][Tt](?=/|$|[^A-Za-z0-9_])|/[Mm][Nn][Tt](?=/|$|[^A-Za-z0-9_])|/[Vv][Oo][Ll][Uu][Mm][Ee][Ss](?=/|$|[^A-Za-z0-9_])|/[Pp][Rr][Ii][Vv][Aa][Tt][Ee](?=/|$|[^A-Za-z0-9_])|[A-Za-z]:(?:/|\\\\)|~(?:/|\\\\)|(?:^|[^A-Za-z0-9_-])[Ss][Kk]-(?:[Pp][Rr][Oo][Jj]-)?[A-Za-z0-9_-]{8,})).*$"
    },
    "position": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "line",
        "character"
      ],
      "properties": {
        "line": {
          "type": "integer",
          "minimum": 0,
          "maximum": 1000000
        },
        "character": {
          "type": "integer",
          "minimum": 0,
          "maximum": 1000000
        }
      }
    },
    "range": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "start",
        "end"
      ],
      "properties": {
        "start": {
          "$ref": "#/$defs/position"
        },
        "end": {
          "$ref": "#/$defs/position"
        }
      },
      "allOf": [
        {
          "properties": {
            "end": {
              "type": "object",
              "properties": {
                "line": {
                  "type": "integer",
                  "minimum": {
                    "$data": "2/start/line"
                  }
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "start": {
                "type": "object",
                "properties": {
                  "line": true
                },
                "required": [
                  "line"
                ]
              },
              "end": {
                "type": "object",
                "properties": {
                  "line": {
                    "type": "integer",
                    "const": {
                      "$data": "2/start/line"
                    }
                  }
                },
                "required": [
                  "line"
                ]
              }
            },
            "required": [
              "start",
              "end"
            ]
          },
          "then": {
            "properties": {
              "end": {
                "type": "object",
                "properties": {
                  "character": {
                    "type": "integer",
                    "minimum": {
                      "$data": "2/start/character"
                    }
                  }
                }
              }
            }
          }
        }
      ]
    },
    "textReplacement": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "range",
        "replacementText"
      ],
      "properties": {
        "range": {
          "$ref": "#/$defs/range"
        },
        "replacementText": {
          "type": "string",
          "maxLength": 8192
        }
      }
    },
    "fileTextEdits": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "workspaceRelativePath",
        "textReplacements"
      ],
      "properties": {
        "workspaceRelativePath": {
          "$ref": "#/$defs/safeRelativePath"
        },
        "textReplacements": {
          "type": "array",
          "minItems": 1,
          "maxItems": 16,
          "items": {
            "$ref": "#/$defs/textReplacement"
          }
        }
      }
    },
    "applyWorkspaceEditPayload": {
      "type": "object",
      "additionalProperties": false,
      "maxTotalReplacementText": 32768,
      "uniquePathsInEdits": true,
      "required": [
        "requiresUserConfirmation",
        "summary",
        "edits"
      ],
      "properties": {
        "requiresUserConfirmation": {
          "type": "boolean",
          "const": true
        },
        "summary": {
          "$ref": "#/$defs/safeSummary"
        },
        "cloudRequired": {
          "type": "boolean",
          "const": false
        },
        "edits": {
          "type": "array",
          "minItems": 1,
          "maxItems": 4,
          "items": {
            "$ref": "#/$defs/fileTextEdits"
          }
        }
      }
    },
    "ideActionType": {
      "type": "string",
      "enum": [
        "getContextSnapshot",
        "openWorkspaceFile",
        "revealWorkspaceRange",
        "getActiveFileExcerpt",
        "runVerificationCommand"
      ]
    },
    "ideActionRequestPayload": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "action"
          ],
          "properties": {
            "action": {
              "const": "getContextSnapshot"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "action"
          ],
          "properties": {
            "action": {
              "const": "getActiveFileExcerpt"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "action",
            "workspaceRelativePath"
          ],
          "properties": {
            "action": {
              "const": "openWorkspaceFile"
            },
            "workspaceRelativePath": {
              "$ref": "#/$defs/safeRelativePath"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "action",
            "workspaceRelativePath",
            "range"
          ],
          "properties": {
            "action": {
              "const": "revealWorkspaceRange"
            },
            "workspaceRelativePath": {
              "$ref": "#/$defs/safeRelativePath"
            },
            "range": {
              "$ref": "#/$defs/range"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "action",
            "commandId"
          ],
          "properties": {
            "action": {
              "const": "runVerificationCommand"
            },
            "commandId": {
              "$ref": "#/$defs/verificationCommandId"
            }
          }
        }
      ]
    },
    "verificationCommandId": {
      "type": "string",
      "enum": [
        "repository-check",
        "gui-app-tests",
        "engine-chat-tests"
      ]
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "type": {
            "const": "gui.ready"
          }
        },
        "required": [
          "type"
        ]
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "supportedBridgeVersion": {
                "type": "string",
                "const": "2026-05-15"
              },
              "frameNonce": {
                "type": "string",
                "pattern": "^[0-9a-f]{32}$"
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "gui.unloaded"
          }
        },
        "required": [
          "type"
        ]
      },
      "then": {
        "not": {
          "properties": {
            "requestId": true
          },
          "required": [
            "requestId"
          ]
        },
        "properties": {
          "payload": {
            "type": "object",
            "additionalProperties": false
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "gui.ideActionRequest"
          }
        },
        "required": [
          "type"
        ]
      },
      "then": {
        "required": [
          "requestId",
          "payload"
        ],
        "properties": {
          "requestId": {
            "$ref": "#/$defs/requestId"
          },
          "payload": {
            "$ref": "#/$defs/ideActionRequestPayload"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "gui.applyWorkspaceEditRequest"
          }
        },
        "required": [
          "type"
        ]
      },
      "then": {
        "required": [
          "requestId",
          "payload"
        ],
        "properties": {
          "requestId": {
            "$ref": "#/$defs/requestId"
          },
          "payload": {
            "$ref": "#/$defs/applyWorkspaceEditPayload"
          }
        }
      }
    }
  ]
}
