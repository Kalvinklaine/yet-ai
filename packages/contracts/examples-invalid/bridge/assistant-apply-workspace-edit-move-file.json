{
  "version": "2026-05-15",
  "type": "gui.applyWorkspaceEditRequest",
  "payload": {
    "requiresUserConfirmation": true,
    "summary": "Move a helper file.",
    "cloudRequired": false,
    "edits": [
      {
        "workspaceRelativePath": "src/old-helper.ts",
        "moveFile": {
          "newWorkspaceRelativePath": "src/utils/helper.ts"
        },
        "textReplacements": [
          {
            "range": {
              "start": { "line": 0, "character": 0 },
              "end": { "line": 0, "character": 0 }
            },
            "replacementText": ""
          }
        ]
      }
    ]
  }
}
