{
  "kind": "experimental_sandbox_session",
  "version": "2026-06-21",
  "mode": "sandbox_experimental",
  "defaultEnabled": false,
  "cloudRequired": false,
  "authority": "metadata_only",
  "executionAllowed": false,
  "modeStatus": "opted_in",
  "limits": {
    "maxSteps": 6,
    "maxTouchedFiles": 4,
    "maxPatchBytes": 12000,
    "maxRuntimeSeconds": 600,
    "workspaceRelativePaths": [
      "apps/gui/src/App.tsx",
      "docs/README.md"
    ]
  }
}
